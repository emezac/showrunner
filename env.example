# Copy this file to .env and replace the placeholder with your Qwen Cloud key.
# Never commit the real .env file or expose its credentials in logs, screenshots,
# chats, commits, or tickets. Rotate the key immediately if it is disclosed.

# Qwen Cloud / DashScope credential.
QWEN_TOKEN="sk-your-qwen-cloud-token"

# OpenAI-compatible endpoint used by the current Qwen Cloud configuration.
# QWEN_BASE_URL is also accepted and takes precedence when both are present.
base_url="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"

# Default Qwen model used by the current project configuration.
# QWEN_MODEL is also accepted and takes precedence when both are present.
model1="qwen3.7-plus"
