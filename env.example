# Nunca commitear un .env real. Este archivo es solo la plantilla.

# Clave de Qwen Cloud (sirve tanto para QwenRouter como para HappyHorseClient).
# Si compartiste tu clave real en un chat/commit/ticket, rótala en la consola
# de Qwen Cloud antes de usarla aquí.
QWEN_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endpoint OpenAI-compatible para llamadas LLM (guion, clasificación, storyboard)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max
QWEN_VISION_MODEL=qwen3.7-plus

# true: never assemble a final cut when clip-level vision QA is unavailable or
# still reports failed shots after one automatic repair attempt.
CONSISTENCY_STRICT=true

# Host nativo de DashScope para síntesis de vídeo HappyHorse (distinto endpoint)
DASHSCOPE_HOST=dashscope-intl.aliyuncs.com
HAPPYHORSE_MODEL=happyhorse-1.1
