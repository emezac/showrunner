<div id="toast-stack"></div>
<% is_editable = %w[awaiting_storyboard_approval failed completed].include?(@project.status) && @project.direction["pipeline_mode"] != "agentic" %>
<% recoverable_status = %w[awaiting_storyboard_approval failed completed].include?(@project.status) %>
<% can_regenerate_images = recoverable_status %>
<% consistency = (@project.manifest || {})["consistency_report"] || {} %>
<% visual_metrics = consistency["visual_metrics"] || {} %>
<% video_metrics = (@project.manifest || {})["video_consistency_report"] || {} %>
<% script_consistency = consistency["script_consistency"] || @screenplay["script_consistency_report"] || {} %>
<% fidelity = consistency["asset_fidelity"] || (@project.manifest || {}).dig("assets", "profiling_report") || {} %>
<% visual_required = !@project.dry_run? %>
<% failed_visual_ids = Array(visual_metrics["failed_shot_ids"]).map(&:to_s) %>
<% failed_video_ids = Array(video_metrics["failed_shot_ids"]).map(&:to_s) %>
<% unavailable_video_ids = Array(video_metrics["audit_unavailable_shot_ids"]).map(&:to_s) %>
<% automatic_video_repairs = Array(video_metrics["automatic_repairs_attempted"]).map(&:to_s) %>
<% video_override_applied = ActiveRecord::Type::Boolean.new.cast(video_metrics["override_applied"]) %>
<% video_gate_failed = !video_override_applied && (failed_video_ids.any? || (video_metrics["status"].present? && video_metrics["status"] != "measured")) %>
<% pending_video_review = (@project.manifest || {})["pending_video_review"] || {} %>
<% pending_video_available = ActiveRecord::Type::Boolean.new.cast(pending_video_review["available"]) %>
<% nested_override_applied = ActiveRecord::Type::Boolean.new.cast(consistency.dig("visual_qa_override", "applied")) %>
<% visual_override_active = nested_override_applied && ConsistencyOverridePolicy.valid?(manifest: @project.manifest || {}, screenplay: @screenplay) %>
<% historical_visual_risk_accepted = video_override_applied || (@project.status == "completed" && nested_override_applied) %>
<% approval_blocked = consistency["ready_for_render"] == false || (visual_required && visual_metrics["status"] != "measured") || (failed_visual_ids.any? && !visual_override_active) || video_gate_failed %>
<% gate_state = if visual_metrics["status"] != "measured"
                  "pending"
                elsif (failed_visual_ids.any? && (visual_override_active || historical_visual_risk_accepted)) || (failed_video_ids.any? && video_override_applied)
                  "overridden"
                elsif consistency["ready_for_render"] == false || failed_visual_ids.any? || video_gate_failed
                  "failed"
                else
                  "passed"
                end %>
<% gate_state_label = gate_state == "overridden" ? "RISK ACCEPTED" : gate_state.upcase %>
<% visual_override_available = ConsistencyOverridePolicy.overrideable?(consistency) || video_gate_failed %>
<% partial_visual_count = Array(visual_metrics["partial_shots"]).size %>
<% total_storyboard_shots = Array(@screenplay["scenes"]).sum { |scene| Array(scene["shots"]).size } %>
<% mode_configuration = ProductionModePolicy.resolve(input: @project.direction || {}, prompt: @project.prompt) %>
<% mode_configuration_errors = mode_configuration["errors"] %>
<% checkpoint_stage = @preproduction_checkpoint_stage.to_s %>
<% checkpoint_rank = PreproductionCheckpoint::STAGES.index(checkpoint_stage) || -1 %>
<% render_runtime = (@project.manifest || {})["render_runtime"] || {} %>

<div class="wrap">
  <!-- TOPBAR -->
  <div class="topbar">
    <div class="brand">
      <%= link_to projects_path do %>
        <div class="mark"></div>
      <% end %>
      <div class="word">SHOWRUNNER <span>· qwen cloud</span></div>
    </div>
    <div style="display: flex; gap: 1rem; align-items: center;">
      <%= link_to "Architecture & Components", architecture_path, style: "font-family: var(--font-mono); font-size: 0.72rem; color: var(--amber); text-decoration: none; border: 1px solid rgba(227, 163, 77, 0.3); padding: 0.35rem 0.95rem; border-radius: 100px; background: rgba(227, 163, 77, 0.05); letter-spacing: 0.05em; text-transform: uppercase; transition: all 0.2s ease;", class: "btn-tech-spec" %>
      <div class="status-pill <% if @project.status == 'rendering' || @project.status == 'planning' %>live<% elsif @project.status == 'awaiting_storyboard_approval' %>ready<% elsif @project.status == 'completed' %>done<% end %>" id="statusPill">
        <div class="dot"></div>
        <% public_status = { "planning" => "Building pre-production", "awaiting_storyboard_approval" => "Ready for review", "rendering" => "Producing final film", "completed" => "Final cut ready", "failed" => "Needs attention" } %>
        <span id="statusText"><%= public_status.fetch(@project.status, @project.status.to_s.humanize) %></span>
      </div>
    </div>
  </div>

  <% unless @project.status == "draft" %>
    <% planning_stage = { "screenplay" => 1, "assets" => 2, "storyboard" => 3, "visual_qa" => 3, "completed" => 3 }.fetch(checkpoint_stage, 0) %>
    <% active_stage = @project.status == "planning" ? planning_stage : { "awaiting_storyboard_approval" => 3, "rendering" => 4, "completed" => 6, "failed" => 3 }.fetch(@project.status, 0) %>
    <section class="production-stagebar" aria-label="Production pipeline">
      <div class="production-stagebar__head">
        <span>Production pipeline</span>
        <strong id="pipeline-progress-label"><%= active_stage == 6 ? "Complete" : "Stage #{active_stage + 1} of 6" %></strong>
      </div>
      <div class="production-stagebar__track"><span id="pipeline-progress-fill" style="width: <%= active_stage == 6 ? 100 : [active_stage * 18 + 10, 92].min %>%"></span></div>
      <ol>
        <% ["Narrative", "Visual bible", "Storyboard", "Consistency QA", "Video production", "Edit & delivery"].each_with_index do |label, index| %>
          <li class="<%= 'done' if index < active_stage %> <%= 'active' if index == active_stage && active_stage < 6 %>" data-pipeline-stage="<%= %w[narrative visual_bible storyboard consistency_qa video_production edit_delivery][index] %>"><span><%= index < active_stage ? "✓" : index + 1 %></span><%= label %></li>
        <% end %>
      </ol>
    </section>
  <% end %>

  <!-- COMPOSER AREA (Only visible if not rendering or planning) -->
  <% if @project.status == "draft" %>
    <div class="hero">
      <div class="composer">
        <textarea id="promptInput" placeholder="Describe your story..."><%= @project.prompt %></textarea>
        <div class="composer-foot">
          <div class="suggest-row" id="suggestRow">
            <span class="tag">Copilot</span>
          </div>
          <%= button_to "Produce", render_video_project_path(@project), class: "btn btn-primary", id: "produceBtn" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- 3-STEP WIZARD NAVIGATION -->
  <% if @project.status != "draft" %>
    <div style="display: flex; gap: 1.5rem; justify-content: center; margin-bottom: 2rem; margin-top: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 1.2rem; flex-wrap: wrap;" class="step-nav">
      <button class="step-nav-btn active" id="tab-btn-script" onclick="switchWizardTab('script')">
        <span class="step-num">1</span>
        <span class="step-lbl">
          Screenplay Script
          <% if @project.status == "planning" && checkpoint_rank < 0 %>
            <span class="spinner-mini" style="display: inline-block; width: 10px; height: 10px; border: 2px solid rgba(227,163,77,0.2); border-top-color: var(--amber); border-radius: 50%; animation: spin 1s linear infinite; margin-left: 0.3rem; vertical-align: middle;"></span>
          <% elsif @project.status == "planning" %>
            <span style="color:var(--teal); margin-left:.3rem;" title="Durably saved">✓</span>
          <% end %>
        </span>
      </button>
      <button class="step-nav-btn" id="tab-btn-assets" onclick="switchWizardTab('assets')">
        <span class="step-num">2</span>
        <span class="step-lbl">
          Character & Location Assets
          <% if @project.status == "planning" && checkpoint_rank < 0 %>
            <span style="font-size: 0.75rem; margin-left: 0.3rem; opacity: 0.6;" title="Locked until script is finalized">🔒</span>
          <% elsif @project.status == "planning" && checkpoint_rank < 1 %>
            <span class="spinner-mini" style="display:inline-block; width:10px; height:10px; border:2px solid rgba(227,163,77,.2); border-top-color:var(--amber); border-radius:50%; animation:spin 1s linear infinite; margin-left:.3rem; vertical-align:middle;"></span>
          <% elsif @project.status == "planning" %>
            <span style="color:var(--teal); margin-left:.3rem;" title="Durably saved">✓</span>
          <% end %>
        </span>
      </button>
      <button class="step-nav-btn" id="tab-btn-storyboard" onclick="switchWizardTab('storyboard')">
        <span class="step-num">3</span>
        <span class="step-lbl">
          Storyboard & Render
          <% if @project.status == "planning" && checkpoint_rank < 1 %>
            <span style="font-size: 0.75rem; margin-left: 0.3rem; opacity: 0.6;">🔒</span>
          <% elsif @project.status == "planning" && checkpoint_rank < 2 %>
            <span class="spinner-mini" style="display:inline-block; width:10px; height:10px; border:2px solid rgba(227,163,77,.2); border-top-color:var(--amber); border-radius:50%; animation:spin 1s linear infinite; margin-left:.3rem; vertical-align:middle;"></span>
          <% elsif @project.status == "planning" %>
            <span style="color:var(--teal); margin-left:.3rem;" title="Durably saved">✓</span>
          <% elsif @project.status == "rendering" %>
            <span class="spinner-mini" style="display: inline-block; width: 10px; height: 10px; border: 2px solid rgba(16,185,129,0.2); border-top-color: #10b981; border-radius: 50%; animation: spin 1s linear infinite; margin-left: 0.3rem; vertical-align: middle;"></span>
          <% end %>
        </span>
      </button>
    </div>
  <% end %>

  <!-- DASHBOARD CONTAINER -->
  <div id="dashboard" class="visible" style="margin-top: 24px;">
    <div class="grid">
      
      <!-- GLOBAL SIDEBAR COLUMN (340px on desktop) -->
      <div class="col" style="display: flex; flex-direction: column; gap: 1.5rem; max-width: 340px;">
        
        <!-- GLOBAL APPROVAL BUTTON -->
        <% if recoverable_status %>
          <div class="panel" style="padding: 1.5rem; border: 1px solid var(--amber); background: rgba(227,163,77,0.02);">
            <h3 style="color: var(--amber); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; font-size: 1rem;">
              Production controls
            </h3>
            <p style="color: var(--steel-dim); font-size: 0.82rem; line-height: 1.5; margin-bottom: 1.2rem;">
              Regeneration and QA recovery remain available even when the consistency gate is blocked.
            </p>
            <% if mode_configuration_errors.any? %>
              <div style="border:1px solid rgba(245,158,11,.5); background:rgba(245,158,11,.08); border-radius:10px; padding:.8rem; margin-bottom:.9rem; color:#fcd34d; font-size:.72rem; line-height:1.45;">
                <strong style="display:block; margin-bottom:.35rem;">Full Control needs explicit choices</strong>
                <%= mode_configuration_errors.join(" · ") %>. Set them in Direction before producing.
              </div>
            <% end %>
            <% if @project.status == "failed" && (render_runtime["error"].present? || render_runtime["outcome"].present?) %>
              <div id="lastRenderOutcome" style="border:1px solid rgba(239,68,68,.45); background:rgba(239,68,68,.06); border-radius:10px; padding:.8rem; margin-bottom:.9rem; color:#fecaca; font-size:.72rem; line-height:1.45;">
                <strong style="display:block; margin-bottom:.35rem; text-transform:uppercase; letter-spacing:.05em; font-family:var(--font-mono);">Last production attempt stopped before completion</strong>
                <%= render_runtime["error"].presence || render_runtime["outcome"].to_s.humanize %>
                <% if render_runtime["outcome"].to_s.include?("before_video_synthesis") %>
                  <span style="display:block; margin-top:.35rem; color:var(--steel-dim);">No video synthesis was started in that attempt.</span>
                <% end %>
              </div>
            <% end %>
            <% if failed_visual_ids.any? %>
              <div id="failedKeyframeActions" style="border:1px solid rgba(239,68,68,.45); background:rgba(239,68,68,.06); border-radius:10px; padding:.85rem; margin-bottom:.9rem;">
                <strong style="display:block; color:#fca5a5; font-family:var(--font-mono); font-size:.72rem; margin-bottom:.55rem; text-transform:uppercase; letter-spacing:.05em;">
                  Visual correction required
                </strong>
                <% failed_visual_ids.each do |shot_id| %>
                  <button type="button" data-failed-keyframe-action="<%= shot_id %>"
                          aria-label="Regenerate failed keyframe <%= shot_id %>"
                          onclick="window.regenerateShotImage('<%= shot_id %>', this)"
                          class="btn btn-ghost" style="width:100%; justify-content:center; border-color:#ef4444; color:#fecaca; font-family:var(--font-mono); margin-bottom:.45rem;">
                    Fix failed keyframe <%= shot_id %>
                  </button>
                <% end %>
                <p style="font-size:.66rem; color:var(--steel-dim); line-height:1.4; margin:.2rem 0 0;">
                  Regenerates only the failed image and immediately reruns visual QA.
                  <% if @project.tokens_remaining.to_i <= 0 %>Enable “Allow Spending Beyond the Token Limit” below first.<% end %>
                </p>
              </div>
            <% end %>
            <% if video_gate_failed %>
              <div id="failedVideoActions" style="border:1px solid rgba(239,68,68,.45); background:rgba(239,68,68,.06); border-radius:10px; padding:.85rem; margin-bottom:.9rem;">
                <strong style="display:block; color:#fca5a5; font-family:var(--font-mono); font-size:.72rem; margin-bottom:.45rem; text-transform:uppercase; letter-spacing:.05em;">
                  <% if unavailable_video_ids.any? %>
                    Final video QA incomplete: <%= unavailable_video_ids.join(', ') %>
                  <% else %>
                    Final video QA failed<%= failed_video_ids.any? ? ": #{failed_video_ids.join(', ')}" : "" %>
                  <% end %>
                </strong>
                <p style="font-size:.68rem; color:var(--steel-dim); line-height:1.45; margin:0;">
                  <% if pending_video_available %>
                    The complete cut is preserved. You can accept this exact cut without rendering again or spending more tokens or video credits.
                  <% else %>
                    This failure predates recoverable render checkpoints. A new render is required, but an explicit visual-risk authorization will now remain valid through final video QA.
                  <% end %>
                </p>
              </div>
            <% end %>
            <% if approval_blocked %>
              <% if visual_metrics["status"] != "measured" || failed_visual_ids.any? %>
                <button type="button" id="rerunVisualQaBtn" onclick="window.rerunVisualQa(this)"
                        class="btn btn-primary" style="width:100%; justify-content:center; margin-bottom:.7rem; font-family:var(--font-mono);">
                  Retry Visual QA Only
                </button>
                <p style="font-size:.68rem; color:var(--steel-dim); line-height:1.4; margin:-.25rem 0 .8rem;">
                  Rechecks existing images without regenerating them or using image credits. With token overrun ON, it can complete every QA batch.
                </p>
              <% end %>
              <% if video_gate_failed %>
                <%= button_to render_video_project_path(@project), method: :post,
                      params: { retry_video_qa: true, allow_token_overrun: false },
                      class: "btn btn-primary", style: "width:100%; justify-content:center; margin-bottom:.7rem; font-family:var(--font-mono);",
                      id: "retryFinalVideoQaBtn" do %>
                  <%= failed_video_ids.any? ? "Repair Failed Clips & Retry Final Video QA" : "Retry Final Video QA Only" %>
                <% end %>
                <p style="font-size:.68rem; color:var(--steel-dim); line-height:1.4; margin:-.25rem 0 .8rem;">
                  Approved clips are reused. Audit-unavailable clips are rechecked without regeneration; only genuinely failed clips may spend video credits.
                </p>
              <% end %>
              <% if visual_override_available %>
                <%= button_to render_video_project_path(@project), method: :post,
                      params: { allow_visual_qa_override: true, allow_token_overrun: false },
                      data: { turbo_confirm: pending_video_available ? "Use the already assembled final cut and explicitly accept its reported visual-QA failures? No new tokens or video credits will be used." : "Generate the video with a one-render visual-risk authorization? Automatic repair and final video QA will still run, but remaining visual-only failures will be recorded as warnings instead of discarding the cut." },
                      class: "btn btn-ghost", style: "width:100%; justify-content:center; border-color:#ef4444; color:#fca5a5; font-family:var(--font-mono);" do %>
                  <%= pending_video_available ? "Use Existing Cut and Accept Video Risk" : (video_gate_failed ? "Re-render Video and Accept Visual Risk" : "Generate Video and Accept Visual Risk") %>
                <% end %>
              <% end %>
            <% else %>
              <% production_path = @project.status == "awaiting_storyboard_approval" ? approve_storyboard_project_path(@project) : render_video_project_path(@project) %>
              <%= button_to production_path, method: :post,
                    params: { allow_token_overrun: false },
                    class: "btn btn-primary", style: "width:100%; text-align:center; justify-content:center; font-weight:bold; font-family:var(--font-mono);",
                    id: "approveBtn" do %>
                Approve & Render 🎬
              <% end %>
            <% end %>
          </div>
        <% end %>

        <div class="panel" id="consistencyGate" data-gate-state="<%= gate_state %>" style="border-color: <%= { "failed" => '#ef4444', "passed" => '#10b981', "pending" => '#f59e0b', "overridden" => '#f59e0b' }[gate_state] %>;">
          <h3>Consistency Gate · <span id="gateStateLabel"><%= gate_state_label %></span></h3>
          <div class="budget-nums">
            <span>Structural contract</span>
            <span class="mono" id="structuralScore"><%= consistency["structural_score"] || "—" %>/100</span>
          </div>
          <div class="budget-nums">
            <span>Script consistency</span>
            <span class="mono" id="scriptConsistencyScore"><%= script_consistency["status"] == "ready" ? "READY#{script_consistency['resolved_count'].to_i.positive? ? " · #{script_consistency['resolved_count']} fixed" : ''}" : (script_consistency["status"] == "blocked" ? "BLOCKED" : "pending") %></span>
          </div>
          <div class="budget-nums">
            <span>Source ↔ asset fidelity</span>
            <span class="mono" id="fidelityScore"><%= fidelity["score"] ? "#{fidelity['score']}/100" : "—" %></span>
          </div>
          <div class="budget-nums">
            <span>Storyboard vision QA</span>
            <span class="mono" id="visualScore"><%= visual_metrics["status"] == "measured" ? "#{visual_metrics['average_score'] || '—'}/100" : (partial_visual_count.positive? ? "PARTIAL #{partial_visual_count}/#{total_storyboard_shots}" : (gate_state == "failed" ? "blocked" : "pending")) %></span>
          </div>
          <div class="budget-nums">
            <span>Final video QA</span>
            <span class="mono" id="videoVisualScore"><%= if video_metrics["status"] == "measured"
                                                              "#{video_metrics['average_score'] || '—'}/100#{video_override_applied ? ' · RISK ACCEPTED' : ''}"
                                                            elsif video_metrics["status"].present?
                                                              "BLOCKED"
                                                            else
                                                              "not rendered"
                                                            end %></span>
          </div>
          <% critical_issues = Array(consistency["issues"]).select { |issue| issue["severity"] == "critical" } %>
          <% gate_message = if failed_video_ids.any?
                              if video_override_applied
                                "Final-video visual risk accepted for clips: #{failed_video_ids.join(', ')}"
                              elsif automatic_video_repairs.any?
                                "Final video QA rejected clips after one bounded automatic repair: #{failed_video_ids.join(', ')}"
                              elsif video_metrics["repair_policy"] == "disabled_by_full_control"
                                "Final video QA rejected clips in Full Control; no automatic clip repair was run: #{failed_video_ids.join(', ')}"
                              else
                                "Final video QA rejected clips: #{failed_video_ids.join(', ')}"
                              end
                            elsif video_gate_failed
                              unavailable_video_ids.any? ? "Final video QA could not measure clips #{unavailable_video_ids.join(', ')}; the existing clips will be re-audited, not regenerated." : "Final video QA was unavailable: #{video_metrics['reason']}"
                            elsif failed_visual_ids.any?
                              visual_override_active ? "Visual risk was accepted for these exact keyframes; correction is still recommended: #{failed_visual_ids.join(', ')}" : "Review/regenerate failed keyframes: #{failed_visual_ids.join(', ')}"
                            elsif partial_visual_count.positive?
                              "QA partial: #{partial_visual_count}/#{total_storyboard_shots} keyframes measured. Retry only visual QA to complete it."
                            elsif critical_issues.any?
                              critical_issues.first(3).map { |issue| issue["message"] }.join(" · ")
                            else
                              "Final clips are sampled and audited again before editing."
                            end %>
          <p id="gateIssueMessage" style="color: <%= gate_state == 'overridden' ? '#f59e0b' : ((failed_video_ids.any? || video_gate_failed || failed_visual_ids.any? || critical_issues.any?) ? '#ef4444' : 'var(--steel-dim)') %>; font-size: 0.78rem; line-height: 1.45; margin-top: 0.8rem;">
            <%= gate_message %>
          </p>
        </div>

        <!-- PRODUCTION BUDGET -->
        <div class="panel">
          <h3>Production Budget</h3>
          <% budget_pct = 100 - ((@project.tokens_remaining || @project.token_budget).to_f / @project.token_budget * 100) %>
          <% tokens_over_budget = [@project.tokens_used.to_i - @project.token_budget.to_i, 0].max %>
          <div class="budget-bar"><div id="budgetFill" style="width: <%= budget_pct.clamp(0, 100) %>%"></div></div>
          <div class="budget-nums">
            <span id="budgetUsed"><%= @project.tokens_used %> tokens used</span>
            <span id="budgetLeft"><%= @project.tokens_remaining || @project.token_budget %> remaining</span>
          </div>
          <div id="budgetOverrunRow" class="budget-nums" style="margin-top: 5px; color: #f59e0b; display: <%= tokens_over_budget.positive? ? 'flex' : 'none' %>;">
            <span>Token overrun</span>
            <span id="budgetOverrun" class="mono"><%= tokens_over_budget %> tokens</span>
          </div>
          <div class="budget-nums" style="margin-top: 6px;">
            <span>Video Credits</span>
            <span id="videoCredits" class="mono"><%= @project.video_credits_used %></span>
          </div>
          <div class="budget-nums">
            <span>Average Render Time</span>
            <% avg_time = @project.render_timings.average(:total_seconds) || RenderTiming.average(:total_seconds) || 120 %>
            <span id="renderEta" class="mono">≈ <%= avg_time.round %> s</span>
          </div>
          
          <div class="ledger-log" id="ledgerLog">
            <div class="ledger-item"><b>Initial Planning</b><span>+<%= @project.tokens_used %> tok</span></div>
          </div>

          <div class="assist-note">
            <span>UI Assistances (Copilot)</span>
            <span id="assistTokens" class="mono"><%= @project.ui_assist_ledger_entries.sum(:tokens_used) %> tokens</span>
          </div>

          <button type="button" id="tokenOverrunToggle" aria-pressed="false" onclick="window.toggleTokenOverrun()"
                  style="width:100%; margin-top:12px; padding:10px 12px; border-radius:10px; border:1px solid rgba(245,158,11,.38); background:rgba(245,158,11,.06); color:var(--steel); cursor:pointer; text-align:left; font:600 .72rem var(--font-mono); line-height:1.35; transition:.2s ease;">
            <span id="tokenOverrunState" style="display:inline-block; min-width:34px; margin-right:7px; color:#f59e0b;">OFF</span>
            Allow Spending Beyond the Token Limit
          </button>
          <p style="margin:7px 2px 0; color:var(--steel-dim); font-size:.68rem; line-height:1.4;">
            One-time authorization for the next regeneration, QA pass, or video render. It turns off automatically.
          </p>
        </div>

        <!-- PROGRESS TERMINAL LOGGER (Visible across all tabs during planning & rendering) -->
        <% if @project.status == "rendering" || @project.status == "planning" %>
          <div class="panel" style="padding: 1.5rem; margin-bottom: 0;">
            <h3>Pipeline Logger (<%= @project.status.titleize %>)</h3>
            <div style="background: #020205; font-family: var(--font-mono); font-size: 0.85rem; padding: 1rem; height: 180px; overflow-y: auto; color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); border-radius: var(--radius-sm);" id="terminal-log">
              <div style="color: var(--steel-dim);">[MONITOR DIRECTED ACTIONCABLE ACTIVE]</div>
              <% if @project.status == "planning" %>
                <% if checkpoint_stage.present? %>
                  <div>▶ Durable checkpoint restored: <%= checkpoint_stage.humanize %></div>
                  <div>▶ Saved usage: <%= number_with_delimiter(@project.tokens_used) %> tokens · <%= @project.video_credits_used.to_i %> image credits</div>
                  <div>▶ Continuing from saved work; completed stages will not be charged again...</div>
                <% else %>
                  <div>▶ Connecting to ShowrunnerAgent...</div>
                  <div>▶ Starting pre-production phase (screenplay & storyboard)...</div>
                <% end %>
              <% else %>
                <div>▶ Connecting to HappyHorse pipeline...</div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div> <!-- end left column -->

      <!-- MAIN CONTENT COLUMN (1fr on desktop, containing tabs) -->
      <div class="col" style="min-width: 0;">
        
        <!-- STEP 1: SCREENPLAY SCRIPT -->
        <div id="wizard-pane-script" style="display: block;">
          <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
            <!-- Slate & DNA on left -->
            <div style="flex: 1; min-width: 280px; display: flex; flex-direction: column; gap: 1.5rem;">
              <!-- PRODUCTION SLATE -->
              <div class="panel slate">
                <h3>Production Slate</h3>
                <div class="slate-top">
                  <div class="clap"></div>
                  <div>
                    <div class="slate-title" id="prodTitle"><%= @project.title.presence || "Untitled" %></div>
                    <div class="slate-genre" id="prodGenre"><%= @story_display["genre_label"] || "Cinematic Drama" %></div>
                  </div>
                </div>
                <div class="slate-row"><span>Duration</span><span id="prodDuration"><%= @project.duration %> s</span></div>
                <div class="slate-row"><span>Resolution</span><span>720P</span></div>
                <div class="slate-row"><span>Emotional Beat</span><span id="prodBeat" style="font-size: 0.8rem; text-align: right;"><%= @story_display["emotional_beat_summary"] || "—" %></span></div>
                <div class="score-badge">
                  <div class="num" id="prodScore"><%= @story_display["quality_score"] || "—" %></div>
                  <div class="lbl">Estimated production<br>score out of 10</div>
                </div>
                <div class="char-list" id="prodChars">
                  <% ui_character_labels = {
                    "protagonista" => "Protagonist",
                    "antagonista" => "Antagonist",
                    "personaje principal" => "Main Character",
                    "personaje secundario" => "Supporting Character"
                  } %>
                  <% Array(@story_display["characters"]).each do |char| %>
                    <span class="char-pill"><%= ui_character_labels.fetch(char.to_s.downcase, char) %></span>
                  <% end %>
                </div>
              </div>

              <!-- STORY DNA -->
              <div class="panel">
                <h3>Story DNA <% if is_editable %><span class="hint">editable</span><% end %></h3>
                <div class="gene-grid" id="geneGrid">
                  <!-- Rendered dynamically by JS -->
                </div>
                <% if is_editable %>
                  <div class="gene-add">
                    <input type="text" id="geneInput" placeholder="Add narrative gene...">
                    <button class="btn btn-ghost btn-sm" id="geneAddBtn">Add</button>
                  </div>
                <% end %>
              </div>

              <!-- DIRECTION -->
              <div class="panel">
                <h3>Direction</h3>

                <div class="dir-block">
                  <div class="dir-label">Genre</div>
                  <div class="pillrow" id="genreRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>
                
                <div class="dir-block">
                  <div class="dir-label">Director Influence</div>
                  <div class="pillrow" id="directorRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>

                <div class="dir-block">
                  <div class="dir-label">Camera Style</div>
                  <div class="pillrow" id="cameraRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>

                <div class="dir-block">
                  <div class="dir-label">Look / Color</div>
                  <div class="swatch-row" id="colorRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>

                <div class="dir-block">
                  <div class="dir-label">Soundtrack</div>
                  <div class="pillrow" id="musicRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>

                <div class="dir-block">
                  <div class="dir-label">Narrator Voice</div>
                  <div class="pillrow" id="voiceRow">
                    <!-- Rendered by JS -->
                  </div>
                </div>
              </div>
            </div>

            <!-- Reasoning & Screenplay script on right -->
            <div style="flex: 1.5; min-width: 320px; display: flex; flex-direction: column; gap: 1.5rem;">
              <!-- SHOWRUNNER REASONING -->
              <div class="panel">
                <h3>Why this story <span class="hint">showrunner reasoning</span></h3>
                <div class="signal-row" id="signalRow">
                  <% Array(@reasoning["detected_signals"]).each do |sig| %>
                    <div class="signal"><%= sig %></div>
                  <% end %>
                </div>
                <div class="structure-flow" id="structureFlow">
                  <% Array(@reasoning["chosen_structure"]).each_with_index do |struct, i| %>
                    <% if i > 0 %><span class="arrow">→</span><% end %>
                    <div class="step"><%= struct %></div>
                  <% end %>
                </div>
              </div>

              <!-- SCREENPLAY SCRIPT TEXT -->
              <% if @screenplay.any? %>
                <div class="panel" style="margin-bottom: 24px;">
                  <h3>Screenplay Script</h3>
                  <div style="font-family: 'Courier New', Courier, monospace; background: rgba(2, 2, 5, 0.8); color: #e2e8f0; padding: 2rem; border-radius: var(--radius-sm); max-height: 400px; overflow-y: auto; border: 1px solid var(--border-color); line-height: 1.6; margin-top: 1rem;">
                    <h2 style="text-align: center; margin-bottom: 2rem; text-transform: uppercase; font-weight: bold; letter-spacing: 0.1em; font-size: 1.3rem; color: var(--text-primary);"><%= @screenplay["title"] || @project.title %></h2>
                    <% screenplay_quality = @manifest&.dig("screenplay_quality_report") || {} %>
                    <% if screenplay_quality.present? %>
                      <div style="display:flex; justify-content:center; gap:1rem; margin:-1rem 0 1.5rem; font-family:var(--font-mono); font-size:0.7rem; color:var(--steel-dim);">
                        <span>Narrative gate: <strong style="color:<%= screenplay_quality["ready_for_storyboard"] ? '#10b981' : '#ef4444' %>;"><%= screenplay_quality["ready_for_storyboard"] ? 'READY' : 'REVIEW' %></strong></span>
                        <span>Score: <strong style="color:var(--parchment);"><%= screenplay_quality["score"] %></strong></span>
                        <span>Planned: <strong style="color:var(--parchment);"><%= screenplay_quality["planned_duration"] %>s</strong></span>
                      </div>
                    <% end %>
                    
                    <% Array(@screenplay["scenes"]).each_with_index do |scene, sc_idx| %>
                      <div class="script-scene" style="margin-bottom: 2rem;">
                        <div class="script-heading" contenteditable="<%= is_editable %>" data-scene-idx="<%= sc_idx %>" data-field="heading" style="font-weight: bold; text-transform: uppercase; margin-bottom: 0.5rem; color: var(--accent-primary); outline: none; border-bottom: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>;" title="<%= is_editable ? 'Click to edit heading' : '' %>">
                          <%= scene["heading"] %>
                        </div>

                        <div style="display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:0.5rem; margin:0.65rem 0 0.9rem; font-size:0.78rem;">
                          <% { "objective" => "Objective", "conflict" => "Conflict", "turn" => "Turn", "outcome" => "Outcome" }.each do |field, label| %>
                            <div style="padding:0.5rem; border:1px solid rgba(255,255,255,0.08); border-radius:4px; background:rgba(255,255,255,0.015);">
                              <div style="font-family:var(--font-mono); color:var(--steel-dim); text-transform:uppercase; font-size:0.63rem; margin-bottom:0.25rem;"><%= label %></div>
                              <div class="script-contract" contenteditable="<%= is_editable %>" data-scene-idx="<%= sc_idx %>" data-field="<%= field %>" style="color:var(--text-secondary); outline:none; border-bottom:1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>;"><%= scene[field] %></div>
                            </div>
                          <% end %>
                        </div>
                        
                        <p class="script-action" contenteditable="<%= is_editable %>" data-scene-idx="<%= sc_idx %>" data-field="action" style="margin-bottom: 1rem; text-align: justify; padding: 0.5rem; color: var(--text-secondary); font-size: 0.95rem; outline: none; border-radius: 4px; border: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>;" title="<%= is_editable ? 'Click to edit action text' : '' %>">
                          <%= scene["action"] %>
                        </p>
                        
                        <% Array(scene["dialogue"]).each_with_index do |dlg, dlg_idx| %>
                          <div class="script-dialogue-block" style="width: 80%; margin: 0 auto 1rem auto; text-align: left;">
                            <div class="script-char" contenteditable="<%= is_editable %>" data-scene-idx="<%= sc_idx %>" data-dlg-idx="<%= dlg_idx %>" data-field="character" style="text-align: center; text-transform: uppercase; font-weight: bold; margin-bottom: 0.2rem; font-size: 0.9rem; color: var(--text-primary); outline: none; border-bottom: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>;" title="<%= is_editable ? 'Click to edit character name' : '' %>">
                              <%= dlg["character"] %>
                            </div>
                            <div class="script-line" contenteditable="<%= is_editable %>" data-scene-idx="<%= sc_idx %>" data-dlg-idx="<%= dlg_idx %>" data-field="line" style="text-align: center; font-size: 0.9rem; line-height: 1.4; color: var(--text-secondary); font-style: italic; outline: none; border-bottom: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>;" title="<%= is_editable ? 'Click to edit dialogue line' : '' %>">
                              <%= dlg["line"] %>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div> <!-- end #wizard-pane-script -->

        <!-- STEP 2: ASSETS PROFILING -->
        <div id="wizard-pane-assets" style="display: none; margin-top: 0;">
          <% if @project.status == "planning" %>
            <div class="panel" style="text-align: center; padding: 4rem 2rem; background: rgba(227,163,77,0.01); border: 1px dashed rgba(227,163,77,0.2); border-radius: var(--radius-sm);">
              <div class="spinner-mini" style="width: 40px; height: 40px; border: 3px solid rgba(227,163,77,0.1); border-top-color: var(--amber); border-radius: 50%; margin: 0 auto 1.5rem auto; animation: spin 1s linear infinite;"></div>
              <h3 style="color: var(--amber); font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Screenplay & Asset Profiling in Progress</h3>
              <p style="color: var(--steel-dim); font-size: 0.9rem; max-width: 500px; margin: 0 auto; line-height: 1.6;">
                Showrunner is currently writing the script. Once the script is completed, characters and locations will be profiled and base frames generated using <b class="mono" style="color: var(--parchment);">wan2.7-image-pro</b>.
              </p>
            </div>
          <% else %>
            <% assets = @manifest["assets"] || { "characters" => [], "props" => [], "locations" => [] } %>
            
            <div style="display: flex; flex-direction: column; gap: 2rem;">
              <!-- Characters Panel -->
              <div class="panel">
                <h3>Character Profiles <span class="hint">physical traits & unique habits</span></h3>
                <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem;">
                  <% if Array(assets["characters"]).empty? %>
                    <div style="color: var(--steel-dim); font-size: 0.9rem; font-style: italic;">No character profiles extracted.</div>
                  <% end %>
                  <% Array(assets["characters"]).each_with_index do |char, idx| %>
                    <div class="asset-card character-card" data-asset-id="<%= char["id"] %>" data-asset-type="characters" style="background: rgba(255,255,255,0.01); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-start;">
                      <div style="position: relative; flex-shrink: 0; width: 120px; height: 120px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); overflow: hidden; background: #020205;">
                        <div id="empty-char-<%= char["id"] %>" <%= 'hidden' if char["image_url"].present? %>
                             style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; padding:1rem; color:var(--steel-dim); font:600 .58rem var(--font-mono); text-align:center; line-height:1.45; letter-spacing:.04em; text-transform:uppercase; background:radial-gradient(circle at 50% 35%, rgba(227,163,77,.11), transparent 58%), #05070a;">
                          Canonical frame required
                        </div>
                        <img id="img-char-<%= char["id"] %>" src="<%= char["image_url"] %>" alt="Canonical reference for <%= char["name"] %>"
                             <%= 'hidden' if char["image_url"].blank? %> class="asset-img"
                             onload="this.hidden=false; document.getElementById('empty-char-<%= char["id"] %>').hidden=true"
                             onerror="this.hidden=true; document.getElementById('empty-char-<%= char["id"] %>').hidden=false"
                             style="width: 100%; height: 100%; object-fit: cover;">
                        <% if can_regenerate_images %>
                          <button type="button" data-idle-label="🔄 Re-Gen Frame" onclick="regenerateAssetImage('<%= char["id"] %>', 'characters', this)" style="position: absolute; z-index:2; bottom: 0; left: 0; right: 0; background: rgba(10,11,16,0.9); border: none; color: var(--amber); font-family: var(--font-mono); font-size: 0.6rem; padding: 0.35rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: center; gap: 0.2rem; transition: background 0.2s ease;">
                            🔄 Re-Gen Frame
                          </button>
                        <% end %>
                      </div>
                      <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 0.8rem; min-width: 0;">
                        <div>
                          <input type="text" class="asset-name-input" value="<%= char["name"] %>" placeholder="Character Name" <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 1.1rem; font-weight: 700; color: var(--parchment); background: none; border: none; border-bottom: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>; outline: none; width: 60%; padding-bottom: 0.1rem;">
                        </div>
                        <div id="asset-status-char-<%= char["id"] %>" class="asset-regeneration-status" role="status" aria-live="polite" hidden></div>
                        
                        <div style="display: flex; gap: 1rem;">
                          <div style="width: 50%;">
                            <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Physical Appearance</div>
                            <textarea class="asset-phys-desc" placeholder="Details (age, outfit, hair)..." <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; resize: vertical; width: 100%; height: 60px; padding: 0.4rem 0.6rem; line-height: 1.4;"><%= char["physical_description"] %></textarea>
                          </div>
                          
                          <div style="width: 50%; display: flex; flex-direction: column; gap: 0.6rem;">
                            <div>
                              <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Personality Traits</div>
                              <input type="text" class="asset-traits" value="<%= char["personality_traits"] %>" placeholder="Traits (bold, quiet...)" <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; width: 100%; padding: 0.4rem 0.6rem;">
                            </div>
                            <div>
                              <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Unique Habit / Behavior</div>
                              <input type="text" class="asset-habit" value="<%= char["unique_behavior"] %>" placeholder="Always scratches head..." <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; width: 100%; padding: 0.4rem 0.6rem;">
                            </div>
                          </div>
                        </div>

                        <div>
                          <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Reference Visual Prompt</div>
                          <textarea class="asset-prompt" placeholder="Visual prompt for image model..." <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; resize: vertical; width: 100%; height: 50px; padding: 0.4rem 0.6rem; line-height: 1.4;"><%= char["visual_prompt"] %></textarea>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>

              <!-- Recurring Props Panel -->
              <div class="panel">
                <h3>Canonical Props <span class="hint">materials, scale & physical behavior</span></h3>
                <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem;">
                  <% if Array(assets["props"]).empty? %>
                    <div style="color: var(--steel-dim); font-size: 0.9rem; font-style: italic;">No recurring props extracted.</div>
                  <% end %>
                  <% Array(assets["props"]).each do |prop| %>
                    <div class="asset-card prop-card" data-asset-id="<%= prop["id"] %>" data-asset-type="props" style="background: rgba(255,255,255,0.01); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-start;">
                      <div style="position: relative; flex-shrink: 0; width: 120px; height: 120px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); overflow: hidden; background: #020205;">
                        <img id="img-prop-<%= prop["id"] %>" src="<%= prop["image_url"] %>" class="asset-img" style="width: 100%; height: 100%; object-fit: cover;">
                        <% if can_regenerate_images %>
                          <button type="button" data-idle-label="🔄 Re-Gen Frame" onclick="regenerateAssetImage('<%= prop["id"] %>', 'props', this)" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(10,11,16,0.85); border: none; color: var(--amber); font-family: var(--font-mono); font-size: 0.6rem; padding: 0.35rem; cursor: pointer; text-transform: uppercase;">🔄 Re-Gen Frame</button>
                        <% end %>
                      </div>
                      <div style="flex-grow: 1; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.8rem;">
                        <div id="asset-status-prop-<%= prop["id"] %>" class="asset-regeneration-status" role="status" aria-live="polite" hidden style="grid-column: span 3;"></div>
                        <input type="text" class="asset-name-input" value="<%= prop["name"] %>" placeholder="Prop name" <%= is_editable ? '' : 'disabled' %> style="grid-column: span 2; font: inherit; font-weight: 700; color: var(--parchment); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;">
                        <input type="text" class="asset-dimensions" value="<%= prop["dimensions"] %>" placeholder="Exact/relative size" <%= is_editable ? '' : 'disabled' %> style="font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;">
                        <input type="text" class="asset-color" value="<%= prop["color"] %>" placeholder="Canonical color" <%= is_editable ? '' : 'disabled' %> style="font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;">
                        <input type="text" class="asset-material" value="<%= prop["material"] %>" placeholder="Material" <%= is_editable ? '' : 'disabled' %> style="font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;">
                        <input type="text" class="asset-scale" value="<%= prop["scale_reference"] %>" placeholder="Scale reference" <%= is_editable ? '' : 'disabled' %> style="font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;">
                        <textarea class="asset-desc" placeholder="Canonical description" <%= is_editable ? '' : 'disabled' %> style="grid-column: span 3; font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;"><%= prop["description"] %></textarea>
                        <textarea class="asset-physics" placeholder="Physical constraints, separated by semicolons" <%= is_editable ? '' : 'disabled' %> style="grid-column: span 3; font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;"><%= Array(prop["physical_constraints"]).join("; ") %></textarea>
                        <textarea class="asset-behavior" placeholder="Behavior rules, separated by semicolons" <%= is_editable ? '' : 'disabled' %> style="grid-column: span 3; font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;"><%= Array(prop["behavior_constraints"]).join("; ") %></textarea>
                        <textarea class="asset-prompt" placeholder="Reference visual prompt" <%= is_editable ? '' : 'disabled' %> style="grid-column: span 3; font: inherit; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; padding: 0.5rem;"><%= prop["visual_prompt"] %></textarea>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>

              <!-- Locations Panel -->
              <div class="panel">
                <h3>Location Profiles <span class="hint">scenery & spatial consistency</span></h3>
                <div style="display: flex; flex-direction: column; gap: 1.5rem; margin-top: 1rem;">
                  <% if Array(assets["locations"]).empty? %>
                    <div style="color: var(--steel-dim); font-size: 0.9rem; font-style: italic;">No locations profiled.</div>
                  <% end %>
                  <% Array(assets["locations"]).each_with_index do |loc, idx| %>
                    <div class="asset-card location-card" data-asset-id="<%= loc["id"] %>" data-asset-type="locations" style="background: rgba(255,255,255,0.01); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 1.5rem; display: flex; gap: 1.5rem; align-items: flex-start;">
                      <div style="position: relative; flex-shrink: 0; width: 120px; height: 120px; border-radius: var(--radius-sm); border: 1px solid var(--border-color); overflow: hidden; background: #020205;">
                        <img id="img-loc-<%= loc["id"] %>" src="<%= loc["image_url"] %>" class="asset-img" style="width: 100%; height: 100%; object-fit: cover;">
                        <% if can_regenerate_images %>
                          <button type="button" data-idle-label="🔄 Re-Gen Frame" onclick="regenerateAssetImage('<%= loc["id"] %>', 'locations', this)" style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(10,11,16,0.85); border: none; color: var(--amber); font-family: var(--font-mono); font-size: 0.6rem; padding: 0.35rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: center; gap: 0.2rem; transition: background 0.2s ease;">
                            🔄 Re-Gen Frame
                          </button>
                        <% end %>
                      </div>
                      <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 0.8rem; min-width: 0;">
                        <div>
                          <input type="text" class="asset-name-input" value="<%= loc["name"] %>" placeholder="Location Name" <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 1.1rem; font-weight: 700; color: var(--parchment); background: none; border: none; border-bottom: 1px dashed <%= is_editable ? 'rgba(255,255,255,0.15)' : 'transparent' %>; outline: none; width: 60%; padding-bottom: 0.1rem;">
                        </div>
                        <div id="asset-status-loc-<%= loc["id"] %>" class="asset-regeneration-status" role="status" aria-live="polite" hidden></div>
                        
                        <div style="display: flex; gap: 1rem;">
                          <div style="width: 50%;">
                            <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Spatial Description</div>
                            <textarea class="asset-desc" placeholder="Details (size, background elements)..." <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; resize: vertical; width: 100%; height: 60px; padding: 0.4rem 0.6rem; line-height: 1.4;"><%= loc["description"] %></textarea>
                          </div>
                          
                          <div style="width: 50%; display: flex; flex-direction: column; gap: 0.6rem;">
                            <div>
                              <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Lighting Style</div>
                              <input type="text" class="asset-lighting" value="<%= loc["lighting"] %>" placeholder="Lighting (neon, dim, bright...)" <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; width: 100%; padding: 0.4rem 0.6rem;">
                            </div>
                            <div>
                              <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Atmosphere & Weather</div>
                              <input type="text" class="asset-atmosphere" value="<%= loc["atmosphere"] %>" placeholder="Atmosphere (haze, rain...)" <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; width: 100%; padding: 0.4rem 0.6rem;">
                            </div>
                          </div>
                        </div>

                        <div style="margin-top: 0.2rem;">
                          <div style="font-size: 0.72rem; color: var(--steel-dim); font-family: var(--font-mono); text-transform: uppercase; margin-bottom: 0.2rem; font-weight: 600;">Reference Visual Prompt</div>
                          <textarea class="asset-prompt" placeholder="Visual prompt for background..." <%= is_editable ? '' : 'disabled' %> style="font-family: inherit; font-size: 0.85rem; color: var(--steel); background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 4px; outline: none; resize: vertical; width: 100%; height: 50px; padding: 0.4rem 0.6rem; line-height: 1.4;"><%= loc["visual_prompt"] %></textarea>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
              
              <% if is_editable %>
                <div style="display: flex; justify-content: flex-end; margin-top: 1rem; margin-bottom: 1rem;">
                  <button type="button" class="btn btn-primary" onclick="saveAssetsData()" id="saveAssetsBtn">
                    Save & Sync Storyboard
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
        </div> <!-- end #wizard-pane-assets -->

        <!-- STEP 3: STORYBOARD & RENDERING -->
        <div id="wizard-pane-storyboard" style="display: none;">
          <% if @project.status == "planning" %>
            <div class="panel" style="text-align: center; padding: 4rem 2rem; background: rgba(255,255,255,0.01); border: 1px dashed var(--border-color); border-radius: var(--radius-sm);">
              <div style="font-size: 2rem; margin-bottom: 1.2rem; opacity: 0.7;">🔒</div>
              <h3 style="color: var(--text-primary); font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Waiting for Pre-Production</h3>
              <p style="color: var(--steel-dim); font-size: 0.9rem; max-width: 500px; margin: 0 auto; line-height: 1.6;">
                The Storyboard and rendering suite will become unlocked once the screenplay is written and characters are profiled.
              </p>
            </div>
          <% elsif @project.status == "rendering" %>
            <div class="panel" style="text-align: center; padding: 4rem 2rem; background: rgba(16,185,129,0.01); border: 1px dashed rgba(16,185,129,0.2); border-radius: var(--radius-sm);">
              <div class="spinner-mini" style="width: 40px; height: 40px; border: 3px solid rgba(16,185,129,0.1); border-top-color: #10b981; border-radius: 50%; margin: 0 auto 1.5rem auto; animation: spin 1s linear infinite;"></div>
              <h3 style="color: #10b981; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Rendering & Compiling Final Cut</h3>
              <p style="color: var(--steel-dim); font-size: 0.9rem; max-width: 500px; margin: 0 auto 1rem auto; line-height: 1.6;">
                HappyHorse is generating high-fidelity video clips for each shot using <b class="mono" style="color: var(--parchment);">happyhorse-1.1-i2v</b>. Ffmpeg is assembling transitions and narration audio.
              </p>
              <div style="font-family: var(--font-mono); font-size: 0.8rem; color: #10b981; background: #020205; padding: 0.5rem 1.2rem; border-radius: 4px; display: inline-block; border: 1px solid rgba(16,185,129,0.1);">
                Estimated completion: ~1-2 minutes
              </div>
            </div>
          <% elsif @project.status == "completed" && @project.final_video_url.present? %>
            <div class="panel" style="padding: 2rem; background: #07070b; border: 1px solid var(--border-color); border-radius: var(--radius-sm); margin-bottom: 2rem; text-align: center;">
              <h3 style="color: var(--amber); margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: 0.05em; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                🎬 Final Cut Compiled
              </h3>
              <div style="position: relative; width: 100%; max-width: 800px; margin: 0 auto; aspect-ratio: 16/9; background: #000; border-radius: 4px; overflow: hidden; border: 1px solid var(--border-color); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                <video src="<%= @project.final_video_url %>" controls style="width: 100%; height: 100%; outline: none;" poster="<%= @manifest.dig("screenplay", "scenes", 0, "shots", 0, "image_url") %>">
                  Your browser does not support the video tag.
                </video>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center; max-width: 800px; margin: 1.5rem auto 0 auto; flex-wrap: wrap; gap: 1rem;">
                <div style="color: var(--steel-dim); font-size: 0.85rem;">
                  Rendered in <span class="mono" style="color: var(--parchment);"><%= @project.render_timings.last&.total_seconds&.round || 0 %> seconds</span>
                </div>
                <div style="display: flex; gap: 0.5rem;">
                  <a href="<%= @project.final_video_url %>" download class="btn btn-ghost btn-sm" style="text-decoration: none; padding: 0.45rem 1.2rem; border-radius: 4px; border: 1px solid var(--border-color); font-family: var(--font-mono); font-size: 0.85rem; display: inline-flex; align-items: center; justify-content: center;">
                    Download Video 📥
                  </a>
                  <%= button_to "Re-Render Video", render_video_project_path(@project), method: :post, class: "btn btn-primary btn-sm", style: "font-family: var(--font-mono); font-size: 0.85rem;" %>
                </div>
              </div>
            </div>
          <% end %>

          <!-- STORYBOARD -->
          <% if @screenplay.any? %>
            <div id="storyboardGrid">
              <!-- Rendered by JS -->
            </div>
            <div class="modifier-row" style="margin-top: 1rem;">
              <%= button_to "Generate ending variants (A/B/C)", generate_variant_project_path(@project), method: :post, class: "btn btn-ghost btn-sm", style: "width: 100%;" %>
            </div>
          <% end %>
        </div> <!-- end #wizard-pane-storyboard -->

      </div>

    </div>
  </div>

  <div class="foot-note">Showrunner AI Hackathon — Powered by Qwen Cloud & HappyHorse.</div>
</div>

<style>
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.step-nav-btn {
  background: none; border: none; font-family: 'Inter', sans-serif; cursor: pointer;
  display: flex; align-items: center; gap: 0.6rem; color: var(--steel-dim); font-size: 0.95rem; font-weight: 600;
  padding: 0.6rem 1.2rem; border-radius: var(--radius-sm); border: 1px solid transparent; transition: all 0.2s ease;
  outline: none;
}
.step-nav-btn:hover { color: var(--parchment); }
.step-nav-btn.active {
  color: var(--amber); border-color: rgba(227, 163, 77, 0.3); background: rgba(227, 163, 77, 0.05);
}
.step-nav-btn.active .step-num { background: var(--amber); color: var(--ink); }
.step-num {
  width: 24px; height: 24px; border-radius: 50%; background: var(--steel-dim); color: var(--ink);
  display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold;
}

.asset-card {
  transition: border-color 0.2s ease, background 0.2s ease;
}
.asset-card:hover {
  border-color: rgba(227,163,77,0.2) !important;
  background: rgba(255,255,255,0.02) !important;
}
.scene-card.consistency-failed {
  border-color: rgba(239, 68, 68, .9) !important;
  box-shadow: 0 0 0 1px rgba(239, 68, 68, .28), 0 16px 34px rgba(127, 29, 29, .18);
}
.consistency-failure-badge {
  position: absolute;
  top: .55rem;
  right: .55rem;
  z-index: 12;
  padding: .22rem .45rem;
  border: 1px solid rgba(239, 68, 68, .7);
  border-radius: 999px;
  background: rgba(69, 10, 10, .88);
  color: #fecaca;
  font-family: var(--font-mono);
  font-size: .54rem;
  text-transform: uppercase;
  letter-spacing: .04em;
}
</style>

<!-- GLOBAL INTERACTIVE JAVASCRIPT & STATE MANIPULATION -->
<script>
  (function() {
    // 1. Catalog and static data
    const BEAT_LABELS = {
      mystery: "Mystery", curiosity: "Curiosity", escalation: "Escalation",
      danger: "Danger", climax: "Climax", revelation: "Revelation", aftermath: "Aftermath"
    };

    const BEAT_GRAD = {
      mystery:"linear-gradient(135deg,#141a2e,#232c4a)",
      curiosity:"linear-gradient(135deg,#1a2438,#2c3f57)",
      escalation:"linear-gradient(135deg,#2a1f34,#4a2e4e)",
      danger:"linear-gradient(135deg,#3a1a18,#5c2620)",
      climax:"linear-gradient(135deg,#3d1414,#701f1f)",
      revelation:"linear-gradient(135deg,#3a2a12,#6b4a1c)",
      aftermath:"linear-gradient(135deg,#161a1c,#26302f)"
    };

    const GRADE_FILTERS = {
      none:"none",
      noir:"grayscale(0.85) contrast(1.25)",
      cyberpunk:"hue-rotate(200deg) saturate(1.7) contrast(1.1)",
      kodak:"sepia(0.28) saturate(1.2) contrast(1.05)",
      warm:"hue-rotate(-12deg) saturate(1.15) brightness(1.03)",
      cold:"hue-rotate(150deg) saturate(0.9)",
      apocalyptic:"sepia(0.4) contrast(1.2) saturate(0.7)"
    };

    const GRADE_SWATCH = {
      none:"#3a3d46", noir:"#7c7c7c", cyberpunk:"#7a3ad1", kodak:"#c98a3f",
      warm:"#d16a3f", cold:"#3f8fd1", apocalyptic:"#8a5a2f"
    };

    const GENRES = [
      {id:"sci_fi", label:"Science Fiction"}, {id:"thriller", label:"Thriller / Mystery"},
      {id:"fantasy", label:"Fantasy"}, {id:"drama", label:"Drama"}, {id:"horror", label:"Horror"}
    ];
    const DIRECTORS = ["Nolan", "Villeneuve", "Kurosawa", "Fincher"];
    const CAMERAS = [
      {id:"cinematic", label:"Cinematic"}, 
      {id:"handheld_shaky", label:"Intense Handheld"}, 
      {id:"slow_pans_fixed", label:"Slow & Fixed Pans"}, 
      {id:"dutch_angles_extreme", label:"Dutch Angles"}
    ];
    const COLORS = ["none", "noir", "cyberpunk", "kodak", "warm", "cold", "apocalyptic"];
    const MUSICS = ["none", "epic_orchestral", "cyberpunk_synths", "traditional_japanese", "ambient"];
    const VOICES = [{id:"none", label:"No Narration"}, {id:"male_deep", label:"Male Deep"}, {id:"female_whisper", label:"Female Whisper"}, {id:"robotic_flat", label:"Robotic Flat"}];

    // 2. Application state fed from Rails
    const rawScreenplay = <%= raw @screenplay.to_json %> || {};
    const rawDirection = <%= raw @project.direction.to_json %> || {};
    const preservedGenes = <%= raw (@project.manifest.dig("story", "preserved_genes") || []).to_json %>;

    const state = {
      projectId: <%= @project.id %>,
      status: "<%= @project.status %>",
      isEditable: <%= is_editable.to_json %>,
      canRegenerateImages: <%= can_regenerate_images.to_json %>,
      pipelineMode: rawDirection["pipeline_mode"] || "control",
      genre: rawDirection["genre"] || null,
      genes: [
        {id:"forbidden_love", label:"Forbidden Romance", on: false},
        {id:"sacrifice", label:"Sacrifice", on: false},
        {id:"betrayal", label:"Betrayal", on: false},
        {id:"corruption", label:"Corruption", on: false},
        {id:"loyalty_test", label:"Loyalty Test", on: false},
        {id:"power_struggle", label:"Power Struggle", on: false},
        {id:"awakening", label:"Spiritual Awakening", on: false}
      ],
      director: rawDirection["director_influence"] || null,
      camera: rawDirection["camera_style"] || null,
      color: rawDirection["color_grade"] || null,
      music: rawDirection["music_style"] || null,
      voice: rawDirection["voice_style"] || null,
      allowTokenOverrun: false,
      tokenBudgetExhausted: <%= (@project.tokens_remaining.to_i <= 0).to_json %>,
      failedShotIds: <%= raw failed_visual_ids.to_json %>,
      visualOverrideApplied: <%= visual_override_active.to_json %>,
      scenes: []
    };

    // Initialize active genes from Rails
    state.genes.forEach(g => {
      if (preservedGenes.includes(g.id)) g.on = true;
    });

    // 3-Step Wizard Navigation & Asset Syncing
    window.switchWizardTab = function(tabId) {
      document.getElementById('wizard-pane-script').style.display = 'none';
      document.getElementById('wizard-pane-assets').style.display = 'none';
      document.getElementById('wizard-pane-storyboard').style.display = 'none';
      
      document.getElementById('tab-btn-script').classList.remove('active');
      document.getElementById('tab-btn-assets').classList.remove('active');
      document.getElementById('tab-btn-storyboard').classList.remove('active');
      
      document.getElementById('wizard-pane-' + tabId).style.display = 'block';
      document.getElementById('tab-btn-' + tabId).classList.add('active');
    };

    window.saveAssetsData = function() {
      const saveBtn = document.getElementById("saveAssetsBtn");
      if (saveBtn) {
        saveBtn.disabled = true;
        saveBtn.innerText = "Syncing...";
      }

      const characters = [];
      document.querySelectorAll(".character-card").forEach(card => {
        characters.push({
          id: card.getAttribute("data-asset-id"),
          name: card.querySelector(".asset-name-input").value,
          physical_description: card.querySelector(".asset-phys-desc").value,
          personality_traits: card.querySelector(".asset-traits").value,
          unique_behavior: card.querySelector(".asset-habit").value,
          visual_prompt: card.querySelector(".asset-prompt").value
        });
      });

      const locations = [];
      document.querySelectorAll(".location-card").forEach(card => {
        locations.push({
          id: card.getAttribute("data-asset-id"),
          name: card.querySelector(".asset-name-input").value,
          description: card.querySelector(".asset-desc").value,
          lighting: card.querySelector(".asset-lighting").value,
          atmosphere: card.querySelector(".asset-atmosphere").value,
          visual_prompt: card.querySelector(".asset-prompt").value
        });
      });

      const props = [];
      document.querySelectorAll(".prop-card").forEach(card => {
        props.push({
          id: card.getAttribute("data-asset-id"),
          name: card.querySelector(".asset-name-input").value,
          description: card.querySelector(".asset-desc").value,
          color: card.querySelector(".asset-color").value,
          material: card.querySelector(".asset-material").value,
          dimensions: card.querySelector(".asset-dimensions").value,
          scale_reference: card.querySelector(".asset-scale").value,
          physical_constraints: card.querySelector(".asset-physics").value.split(";").map(value => value.trim()).filter(Boolean),
          behavior_constraints: card.querySelector(".asset-behavior").value.split(";").map(value => value.trim()).filter(Boolean),
          visual_prompt: card.querySelector(".asset-prompt").value
        });
      });

      fetch(`/projects/${state.projectId}/update_metadata`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({
          assets: {
            characters: characters,
            props: props,
            locations: locations
          }
        })
      })
      .then(res => res.json())
      .then(data => {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerText = "Save & Sync Storyboard";
        }
        showToast("Assets saved and Storyboard prompts enriched!");
        setTimeout(() => window.location.reload(), 1000);
      })
      .catch(err => {
        if (saveBtn) {
          saveBtn.disabled = false;
          saveBtn.innerText = "Save & Sync Storyboard";
        }
        showToast("Error saving assets: " + err.message);
      });
    };

    function readJsonResponse(response) {
      return response.json().catch(() => ({})).then(data => {
        if (!response.ok) throw new Error(data.message || `Request failed (${response.status})`);
        return data;
      });
    }

    function forceImageRefresh(element, url, generation) {
      if (!element || !url) return;
      element.removeAttribute("src");
      element.hidden = false;
      element.dataset.generation = generation || Date.now();
      requestAnimationFrame(() => { element.src = url; });
    }

    function applyAssetImages(assetImages, generation) {
      (assetImages || []).forEach(asset => {
        const prefix = asset.asset_type === "characters" ? "char" : (asset.asset_type === "props" ? "prop" : "loc");
        forceImageRefresh(document.getElementById(`img-${prefix}-${asset.asset_id}`), asset.image_url, generation);
      });
    }

    function setTokenOverrun(enabled, announce = true) {
      state.allowTokenOverrun = Boolean(enabled);
      const button = document.getElementById("tokenOverrunToggle");
      const label = document.getElementById("tokenOverrunState");
      if (button) {
        button.setAttribute("aria-pressed", state.allowTokenOverrun ? "true" : "false");
        button.style.background = state.allowTokenOverrun ? "rgba(245,158,11,.18)" : "rgba(245,158,11,.06)";
        button.style.borderColor = state.allowTokenOverrun ? "#f59e0b" : "rgba(245,158,11,.38)";
        button.style.boxShadow = state.allowTokenOverrun ? "0 0 22px rgba(245,158,11,.12)" : "none";
      }
      if (label) label.textContent = state.allowTokenOverrun ? "ON" : "OFF";
      document.querySelectorAll("input[name='allow_token_overrun']").forEach(input => {
        input.value = state.allowTokenOverrun ? "true" : "false";
      });
      if (announce) showToast(state.allowTokenOverrun ? "Extra token spending enabled for the next regeneration, QA, or video render." : "Extra token spending disabled.");
    }

    window.toggleTokenOverrun = function() {
      setTokenOverrun(!state.allowTokenOverrun);
    };

    function resetTokenOverrunAuthorization() {
      if (!state.allowTokenOverrun) return;
      setTokenOverrun(false, false);
    }

    function regenerationBudgetAvailable(silent = false) {
      if (!state.tokenBudgetExhausted || state.allowTokenOverrun) return true;

      if (!silent) showToast("The token budget is exhausted. Enable ‘Allow Spending Beyond the Token Limit’ before regenerating.");
      return false;
    }

    function updateBudgetUsage(budget) {
      if (!budget) return;
      const used = Number(budget.tokens_used || 0);
      const remaining = Number(budget.tokens_remaining || 0);
      const limit = Math.max(Number(budget.token_budget || 0), 1);
      const overrun = Number(budget.tokens_over_budget || 0);
      if (document.getElementById("budgetUsed")) document.getElementById("budgetUsed").textContent = `${used} tokens used`;
      if (document.getElementById("budgetLeft")) document.getElementById("budgetLeft").textContent = `${remaining} remaining`;
      if (document.getElementById("videoCredits")) document.getElementById("videoCredits").textContent = budget.video_credits_used ?? "—";
      if (document.getElementById("budgetFill")) document.getElementById("budgetFill").style.width = `${Math.min((used / limit) * 100, 100)}%`;
      const row = document.getElementById("budgetOverrunRow");
      if (row) row.style.display = overrun > 0 ? "flex" : "none";
      if (document.getElementById("budgetOverrun")) document.getElementById("budgetOverrun").textContent = `${overrun} tokens`;
    }

    function updateConsistencyGate(metrics) {
      if (!metrics) return;
      const gate = document.getElementById("consistencyGate");
      const stateLabel = document.getElementById("gateStateLabel");
      const visualMeasured = metrics.visual_status === "measured";
      const failedIds = (metrics.failed_shot_ids || []).map(String);
      state.failedShotIds = failedIds;
      state.visualOverrideApplied = Boolean(metrics.visual_override_applied);
      const passed = metrics.ready_for_render && visualMeasured && failedIds.length === 0;
      const overridden = metrics.ready_for_render && visualMeasured && failedIds.length > 0 && state.visualOverrideApplied;
      const hasCriticalFailure = metrics.ready_for_render === false && Number(metrics.critical_count || 0) > 0;
      const stateName = passed ? "passed" : (overridden ? "overridden" : ((visualMeasured || hasCriticalFailure) ? "failed" : "pending"));
      const color = passed ? "#10b981" : (stateName === "failed" ? "#ef4444" : "#f59e0b");
      if (gate) { gate.dataset.gateState = stateName; gate.style.borderColor = color; }
      if (stateLabel) { stateLabel.textContent = overridden ? "RISK ACCEPTED" : stateName.toUpperCase(); stateLabel.style.color = color; }
      if (document.getElementById("structuralScore")) document.getElementById("structuralScore").textContent = `${metrics.structural_score ?? "—"}/100`;
      if (document.getElementById("scriptConsistencyScore")) {
        const scriptLabel = metrics.script_status === "ready" ? `READY${Number(metrics.script_resolved_count || 0) > 0 ? ` · ${metrics.script_resolved_count} fixed` : ""}` : (metrics.script_status === "blocked" ? "BLOCKED" : "pending");
        document.getElementById("scriptConsistencyScore").textContent = scriptLabel;
      }
      if (document.getElementById("fidelityScore")) document.getElementById("fidelityScore").textContent = `${metrics.fidelity_score ?? "—"}/100`;
      const partialCount = Number(metrics.partial_shots_evaluated || 0);
      const totalShots = Number(metrics.total_shots || 0);
      if (document.getElementById("visualScore")) {
        document.getElementById("visualScore").textContent = visualMeasured ? `${metrics.visual_score ?? "—"}/100` :
          (partialCount > 0 ? `PARTIAL ${partialCount}/${totalShots || "?"}` : (hasCriticalFailure ? "blocked" : "pending"));
      }
      const issue = document.getElementById("gateIssueMessage");
      if (issue) {
        issue.textContent = failedIds.length ? (overridden ? `Visual risk was accepted for these exact keyframes; correction is still recommended: ${failedIds.join(", ")}` : `Review/regenerate failed keyframes: ${failedIds.join(", ")}`) :
          (partialCount > 0 ? `QA partial: ${partialCount}/${totalShots} keyframes measured. Retry only visual QA to complete it.` : (metrics.visual_reason || "Final clips are sampled and audited again before editing."));
        issue.style.color = stateName === "failed" ? "#ef4444" : (overridden ? "#f59e0b" : "var(--steel-dim)");
      }
      const approve = document.getElementById("approveBtn");
      if (approve) approve.disabled = !(passed || overridden);
    }

    function setRegenerationButton(button, busy, label) {
      if (!button) return;
      if (!button.dataset.idleLabel) button.dataset.idleLabel = button.innerHTML.trim();
      button.disabled = busy;
      button.innerHTML = busy ? "⏳ Generating…" : (button.dataset.idleLabel || label || button.innerHTML);
    }

    function assetStatusId(assetId, assetType) {
      const prefix = assetType === "characters" ? "char" : (assetType === "props" ? "prop" : "loc");
      return `asset-status-${prefix}-${assetId}`;
    }

    function setAssetRegenerationStatus(assetId, assetType, message, tone = "info") {
      const status = document.getElementById(assetStatusId(assetId, assetType));
      if (!status) return null;
      status.hidden = false;
      status.dataset.tone = tone;
      status.replaceChildren(document.createTextNode(message));
      return status;
    }

    function requestAssetTokenAuthorization(assetId, assetType, button) {
      const status = setAssetRegenerationStatus(
        assetId,
        assetType,
        "The production token budget is exhausted. Explicit authorization is required for this regeneration and its consistency-contract rebuild.",
        "warning"
      );
      if (!status) {
        showToast("The token budget is exhausted. Enable ‘Allow Spending Beyond the Token Limit’ before regenerating.");
        return;
      }

      const authorize = document.createElement("button");
      authorize.type = "button";
      authorize.textContent = "Allow Extra Tokens & Regenerate";
      authorize.setAttribute("aria-label", "Allow extra tokens and regenerate this canonical asset");
      authorize.addEventListener("click", () => {
        setTokenOverrun(true, false);
        setAssetRegenerationStatus(assetId, assetType, "Extra-token authorization accepted. Starting regeneration…", "warning");
        window.regenerateAssetImage(assetId, assetType, button);
      }, { once: true });
      status.appendChild(authorize);
      showToast("Regeneration needs one-time extra-token authorization. Use the new button beside this asset.");
    }

    window.regenerateAssetImage = function(assetId, assetType, button) {
      if (!regenerationBudgetAvailable(true)) {
        requestAssetTokenAuthorization(assetId, assetType, button);
        return;
      }
      showToast("Regenerating asset frame via wan2.7-image-pro...");
      setAssetRegenerationStatus(assetId, assetType, "Generating a new canonical frame. The identity and scale contract will be rebuilt before it is accepted…", "info");
      setRegenerationButton(button, true);
      
      fetch(`/projects/${state.projectId}/regenerate_asset_image`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({
          asset_id: assetId,
          asset_type: assetType,
          allow_token_overrun: state.allowTokenOverrun
        })
      })
      .then(readJsonResponse)
      .then(data => {
        if (data.status === "success") {
          const prefix = assetType === "characters" ? "char" : (assetType === "props" ? "prop" : "loc");
          const imgEl = document.getElementById(`img-${prefix}-${assetId}`);
          if (imgEl) {
            forceImageRefresh(imgEl, data.image_url, data.generated_at);
          }
          updateBudgetUsage(data.budget);
          updateConsistencyGate(data.consistency);
          setAssetRegenerationStatus(assetId, assetType, "Canonical frame updated and persisted. Storyboard visual QA is now pending because downstream shots must be checked against this new reference.", "success");
          showToast("Canonical asset regenerated and saved.");
        } else {
          setAssetRegenerationStatus(assetId, assetType, `Regeneration failed: ${data.message}`, "error");
          showToast("Failed: " + data.message);
        }
      })
      .catch(err => {
        setAssetRegenerationStatus(assetId, assetType, `Regeneration failed: ${err.message}`, "error");
        showToast("Error: " + err.message);
      })
      .finally(() => { setRegenerationButton(button, false); resetTokenOverrunAuthorization(); });
    };

    window.regenerateShotImage = function(shotId, button) {
      if (!regenerationBudgetAvailable()) return;
      showToast(`Regenerating shot ${shotId} base frame via wan2.7-image-pro...`);
      setRegenerationButton(button, true);
      
      fetch(`/projects/${state.projectId}/regenerate_shot_image`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({
          shot_id: shotId,
          allow_token_overrun: state.allowTokenOverrun
        })
      })
      .then(readJsonResponse)
      .then(data => {
        if (data.status === "success" || data.status === "partial") {
          // Find shot in state.scenes and update its imageUrl
          const scene = state.scenes.find(s => s.id.toString() === shotId.toString());
          if (scene) {
            scene.imageUrl = data.image_url;
          }
          applyAssetImages(data.asset_images, data.generated_at);
          updateConsistencyGate(data.consistency);
          renderStoryboard();
          updateBudgetUsage(data.budget);
          showToast(data.status === "success" ? "Shot regenerated and visual QA refreshed." : `Shot updated with warnings: ${(data.errors || []).join(" · ")}`);
          setTimeout(() => window.location.reload(), 900);
        } else {
          showToast("Failed: " + data.message);
        }
      })
      .catch(err => {
        showToast("Error: " + err.message);
      })
      .finally(() => { setRegenerationButton(button, false); resetTokenOverrunAuthorization(); });
    };

    window.regenerateSceneImages = function(sceneIdx, button) {
      if (!regenerationBudgetAvailable()) return;
      showToast(`Regenerating base frames for Scene ${sceneIdx + 1} via wan2.7-image-pro...`);
      setRegenerationButton(button, true);
      
      fetch(`/projects/${state.projectId}/regenerate_scene_images`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({
          scene_idx: sceneIdx,
          allow_token_overrun: state.allowTokenOverrun
        })
      })
      .then(readJsonResponse)
      .then(data => {
        if (data.status === "success" || data.status === "partial") {
          // Update all updated image URLs in state.scenes
          data.images.forEach(img => {
            const scene = state.scenes.find(s => s.id.toString() === img.shot_id.toString());
            if (scene) {
              scene.imageUrl = img.image_url;
              const rawShot = (rawScreenplay.scenes || []).flatMap(rawScene => rawScene.shots || []).find(shot => shot.id.toString() === img.shot_id.toString());
              if (rawShot) rawShot.image_url = img.image_url;
            }
          });
          applyAssetImages(data.asset_images, data.generated_at);
          updateConsistencyGate(data.consistency);
          renderStoryboard();
          updateBudgetUsage(data.budget);
          const failed = data.consistency?.failed_shot_ids || [];
          showToast(data.status === "success" && failed.length === 0 ?
            `Scene ${sceneIdx + 1} regenerated and passed visual QA.` :
            `Scene regenerated; remaining QA issues: ${failed.join(", ") || (data.errors || []).join(" · ")}`);
          setTimeout(() => window.location.reload(), 900);
        } else {
          showToast("Failed: " + data.message);
        }
      })
      .catch(err => {
        showToast("Error: " + err.message);
      })
      .finally(() => { setRegenerationButton(button, false); resetTokenOverrunAuthorization(); });
    };

    window.rerunVisualQa = function(button) {
      if (state.tokenBudgetExhausted && !state.allowTokenOverrun) {
        showToast("The token budget is exhausted. Enable ‘Allow Spending Beyond the Token Limit’ to complete visual QA.");
        return;
      }
      showToast("Reviewing the existing images; no image credits will be used...");
      setRegenerationButton(button, true);
      fetch(`/projects/${state.projectId}/rerun_visual_qa`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({ allow_token_overrun: state.allowTokenOverrun })
      })
      .then(readJsonResponse)
      .then(data => {
        updateConsistencyGate(data.consistency);
        updateBudgetUsage(data.budget);
        if (data.consistency?.visual_status === "measured") {
          const failed = data.consistency.failed_shot_ids || [];
          showToast(failed.length ? `Visual QA complete. Shots requiring correction: ${failed.join(", ")}` : "Visual QA complete: ready to generate video.");
        } else {
          showToast(`Visual QA is still incomplete: ${data.consistency?.visual_reason || (data.errors || []).join(" · ")}`);
        }
        setTimeout(() => window.location.reload(), 900);
      })
      .catch(err => showToast("Error: " + err.message))
      .finally(() => { setRegenerationButton(button, false); resetTokenOverrunAuthorization(); });
    };

    // Map scenes and shots from screenplay
    if (rawScreenplay.scenes) {
      rawScreenplay.scenes.forEach((scene, scIdx) => {
        if (scene.shots) {
          scene.shots.forEach(shot => {
            state.scenes.push({
              id: shot.id,
              beat: scene.beat || "mystery",
              camera: shot.camera || "cinematic",
              loc: shot.source_visual_prompt || shot.visual_prompt || "",
              role: shot.editorial_role || "action",
              purpose: shot.purpose || "",
              storyEvent: shot.story_event || "",
              transitionOut: shot.transition_out || {type: "cut", duration: 0},
              duration: shot.duration || 5,
              locked: shot.locked || false,
              imageUrl: shot.image_url || null,
              sceneIdx: scIdx
            });
          });
        }
      });
    }

    const $ = (id) => document.getElementById(id);

    // Toast alert helper
    function showToast(msg) {
      const stack = $("toast-stack");
      const el = document.createElement("div");
      el.className = "toast";
      el.innerHTML = `<div class="tdot"></div><div>${msg}</div>`;
      stack.appendChild(el);
      setTimeout(() => {
        el.style.opacity = "0";
        el.style.transform = "translateY(6px)";
        el.style.transition = "all .3s ease";
        setTimeout(() => el.remove(), 300);
      }, 2600);
    }

    // 3. AJAX/Fetch request to persist changes in Rails
    function persistMetadata() {
      const selectedGenes = state.genes.filter(g => g.on).map(g => g.id);
      const direction = {
        genre: state.genre,
        director_influence: state.director,
        camera_style: state.camera,
        color_grade: state.color,
        music_style: state.music,
        voice_style: state.voice,
        pipeline_mode: state.pipelineMode
      };

      const durations = {};
      const locks = {};
      state.scenes.forEach(s => {
        durations[s.id] = s.duration;
        locks[s.id] = s.locked;
      });

      fetch(`/projects/${state.projectId}/update_metadata`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": document.querySelector("meta[name='csrf-token']").getAttribute("content")
        },
        body: JSON.stringify({
          genes: selectedGenes,
          direction: direction,
          shot_durations: durations,
          locks: locks,
          screenplay: rawScreenplay
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.status === "success") {
          if (data.shot_durations) {
            state.scenes.forEach(shot => {
              if (data.shot_durations[shot.id] !== undefined) shot.duration = data.shot_durations[shot.id];
            });
          }
          if (data.edit_decision_list?.entries) {
            data.edit_decision_list.entries.forEach(entry => {
              const shot = state.scenes.find(item => item.id.toString() === entry.clip_id.toString());
              if (shot) shot.transitionOut = entry.transition_out;
            });
          }
          updateDashboard(data);
          renderTimeline();
          renderStoryboard();
        }
      });
    }

    // Update scores, meters, and reasoning from server JSON response
    function updateDashboard(data) {
      // 1. Slate
      if (data.display) {
        $("prodTitle").textContent = data.display.title;
        $("prodGenre").textContent = data.display.genre_label;
        $("prodBeat").textContent = data.display.emotional_beat_summary;
        $("prodScore").textContent = data.display.quality_score;

        const charList = $("prodChars");
        if (charList) {
          charList.innerHTML = (data.display.characters || []).map(c => `<span class="char-pill">${c}</span>`).join("");
        }
      }

      // 2. Meters
      if (data.quality_meter) {
        setMeter("qDrama", "qDramaN", data.quality_meter.drama);
        setMeter("qAction", "qActionN", data.quality_meter.action);
        setMeter("qVisual", "qVisualN", data.quality_meter.visual_coherence);
        setMeter("qEnding", "qEndingN", data.quality_meter.ending);
      }
      if (data.coherence_metrics) {
        setMeter("cNarr", "cNarrN", data.coherence_metrics.narrative_coherence);
        setMeter("cVis", "cVisN", data.coherence_metrics.visual_consistency);
        setMeter("cChar", "cCharN", data.coherence_metrics.character_consistency);
      }

      // 3. Reasoning
      if (data.reasoning) {
        $("signalRow").innerHTML = (data.reasoning.detected_signals || []).map(s => `<div class="signal">${s}</div>`).join("");
        $("structureFlow").innerHTML = (data.reasoning.chosen_structure || []).map((s, i) => {
          return i === 0 ? `<div class="step">${s}</div>` : `<span class="arrow">→</span><div class="step">${s}</div>`;
        }).join("");
      }
    }

    function setMeter(fillId, numId, val) {
      const fill = $(fillId);
      const num = $(numId);
      if (fill) fill.style.width = val + "%";
      if (num) num.textContent = val + "%";
    }

    // 4. Local UI renderers
    function renderGenes() {
      const grid = $("geneGrid");
      if (!grid) return;
      grid.innerHTML = state.genes.map((g, i) => `
        <div class="gene ${g.on ? 'on' : ''}" data-i="${i}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">
          <div class="box"></div>${g.label}
        </div>`).join("");

      document.querySelectorAll("#geneGrid .gene").forEach(node => {
        node.addEventListener("click", () => {
          if (!state.isEditable) return;
          const i = +node.dataset.i;
          state.genes[i].on = !state.genes[i].on;
          renderGenes();
          showToast(state.genes[i].on ? `Gene "${state.genes[i].label}" activated` : `Gene "${state.genes[i].label}" deactivated`);
          persistMetadata();
        });
      });
    }

    $("geneAddBtn")?.addEventListener("click", () => {
      if (!state.isEditable) return;
      const v = $("geneInput").value.trim();
      if (!v) return;
      state.genes.push({id: v.toLowerCase().replace(/\s+/g,'_'), label: v, on: true});
      $("geneInput").value = "";
      renderGenes();
      persistMetadata();
    });

    function renderDirectionControls() {
      const genreRow = $("genreRow");
      if (genreRow) {
        genreRow.innerHTML = GENRES.map(g => `<div class="pillopt ${state.genre === g.id ? 'on' : ''}" data-g="${g.id}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">${g.label}</div>`).join("");
        document.querySelectorAll("#genreRow .pillopt").forEach(node => node.addEventListener("click", () => {
          if (!state.isEditable) return;
          state.genre = node.dataset.g;
          renderDirectionControls();
          showToast(`Genre: ${node.textContent}`);
          persistMetadata();
        }));
      }

      // 1. Director row
      const dirRow = $("directorRow");
      if (dirRow) {
        dirRow.innerHTML = DIRECTORS.map(d => {
          const key = d.toLowerCase().replace(" ", "_");
          const on = state.director === key;
          return `<div class="pillopt ${on ? 'on' : ''}" data-d="${key}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">${d}</div>`;
        }).join("");
        document.querySelectorAll("#directorRow .pillopt").forEach(node => {
          node.addEventListener("click", () => {
            if (!state.isEditable) return;
            state.director = node.dataset.d;
            renderDirectionControls();
            showToast(`Director influence: ${node.textContent}`);
            persistMetadata();
          });
        });
      }

      // 2. Camera row
      const camRow = $("cameraRow");
      if (camRow) {
        camRow.innerHTML = CAMERAS.map(c => {
          const on = state.camera === c.id;
          return `<div class="pillopt ${on ? 'on' : ''}" data-c="${c.id}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">${c.label}</div>`;
        }).join("");
        document.querySelectorAll("#cameraRow .pillopt").forEach(node => {
          node.addEventListener("click", () => {
            if (!state.isEditable) return;
            state.camera = node.dataset.c;
            renderDirectionControls();
            showToast(`Camera: ${node.textContent}`);
            persistMetadata();
          });
        });
      }

      // 3. Color row (swatches)
      const colRow = $("colorRow");
      if (colRow) {
        colRow.innerHTML = COLORS.map(c => {
          const on = state.color === c;
          return `<div class="swatch ${on ? 'on' : ''}" data-tip="${c}" data-c="${c}" style="background:${GRADE_SWATCH[c]}; cursor: ${state.isEditable ? 'pointer' : 'default'}" tabindex="0"></div>`;
        }).join("");
        document.querySelectorAll("#colorRow .swatch").forEach(node => {
          node.addEventListener("click", () => {
            if (!state.isEditable) return;
            state.color = node.dataset.c;
            renderDirectionControls();
            renderStoryboard(); // Apply CSS filters immediately
            showToast(`Palette applied: ${node.dataset.c}`);
            persistMetadata();
          });
        });
      }

      // 4. Music row
      const musRow = $("musicRow");
      if (musRow) {
        musRow.innerHTML = MUSICS.map(m => {
          const on = state.music === m;
          const label = m.replace(/_/g, " ").replace(/\b\w/g, c => c.toUpperCase());
          return `<div class="pillopt ${on ? 'on' : ''}" data-m="${m}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">${label}</div>`;
        }).join("");
        document.querySelectorAll("#musicRow .pillopt").forEach(node => {
          node.addEventListener("click", () => {
            if (!state.isEditable) return;
            state.music = node.dataset.m;
            renderDirectionControls();
            showToast(`Soundtrack: ${node.textContent}`);
            persistMetadata();
          });
        });
      }

      // 5. Voice row
      const vcRow = $("voiceRow");
      if (vcRow) {
        vcRow.innerHTML = VOICES.map(v => {
          const on = state.voice === v.id;
          return `<div class="pillopt ${on ? 'on' : ''}" data-v="${v.id}" tabindex="0" style="cursor: ${state.isEditable ? 'pointer' : 'default'}">${v.label}</div>`;
        }).join("");
        document.querySelectorAll("#voiceRow .pillopt").forEach(node => {
          node.addEventListener("click", () => {
            if (!state.isEditable) return;
            state.voice = node.dataset.v;
            renderDirectionControls();
            showToast(`Narrator: ${node.textContent}`);
            persistMetadata();
          });
        });
      }
    }

    function renderStoryboard() {
      const grid = $("storyboardGrid");
      if (!grid) return;
      const filter = GRADE_FILTERS[state.color] || "none";

      const scenesGrouped = {};
      state.scenes.forEach((s, idx) => {
        const scIdx = s.sceneIdx;
        if (!scenesGrouped[scIdx]) {
          scenesGrouped[scIdx] = [];
        }
        scenesGrouped[scIdx].push({ shot: s, originalIndex: idx });
      });

      let html = "";
      Object.keys(scenesGrouped).sort((a, b) => a - b).forEach(scIdx => {
        const shotsInScene = scenesGrouped[scIdx];
        const sceneNum = parseInt(scIdx) + 1;

        html += `
          <div class="scene-group" style="margin-bottom: 2rem; border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius-sm); background: rgba(10,11,16,0.25);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0.75rem;">
              <h4 style="font-family: var(--font-mono); text-transform: uppercase; color: var(--accent-primary); font-size: 0.85rem; margin: 0; letter-spacing: 0.05em;">Scene ${sceneNum} · ${rawScreenplay.scenes?.[scIdx]?.heading || ''}</h4>
              ${state.canRegenerateImages ? `
                <button data-regenerate-scene="${scIdx}" onclick="event.stopPropagation(); window.regenerateSceneImages(${scIdx}, this)" class="btn btn-ghost btn-sm" style="font-size: 0.7rem; color: var(--amber); border-color: rgba(245, 158, 11, 0.25); padding: 0.25rem 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-mono);">
                  🔄 Regenerate Images
                </button>
              ` : ''}
            </div>
            <div class="storyboard-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 16px;">
              ${shotsInScene.map(item => {
                const s = item.shot;
                const i = item.originalIndex;
                const hasImg = !!s.imageUrl;
                const consistencyFailed = state.failedShotIds.includes(s.id.toString());
                const bg = hasImg ? 'none' : (BEAT_GRAD[s.beat] || BEAT_GRAD['mystery']);
                return `
                  <div class="scene-card ${s.locked ? 'locked' : ''} ${consistencyFailed ? 'consistency-failed' : ''}" data-i="${i}" data-shot-id="${s.id}">
                    <div class="frame" style="background:${bg}; filter:${filter}; position: relative;">
                      ${hasImg ? `<img src="${s.imageUrl}" style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1;">` : ''}
                      <div class="beat-tag" style="z-index: 3;">${BEAT_LABELS[s.beat] || s.beat}</div>
                      <div class="cam-tag" style="z-index: 3; cursor:${state.isEditable ? 'pointer' : 'default'}" title="${state.isEditable ? 'Click to cycle camera style' : ''}">${s.camera.replace("_", " ")}</div>
                      ${consistencyFailed ? `<div class="consistency-failure-badge">QA failed · ${s.id}</div>` : ''}
                      ${state.canRegenerateImages ? `
                        <button data-regenerate-shot="${s.id}" aria-label="${consistencyFailed ? `Regenerate failed keyframe ${s.id}` : `Regenerate image for shot ${s.id}`}" onclick="event.stopPropagation(); window.regenerateShotImage('${s.id}', this)" style="position: absolute; bottom: 0; left: 0; right: 0; background: ${consistencyFailed ? 'rgba(127,29,29,.92)' : 'rgba(10,11,16,0.85)'}; border: none; color: ${consistencyFailed ? '#fecaca' : 'var(--amber)'}; font-family: var(--font-mono); font-size: 0.55rem; padding: 0.25rem; cursor: pointer; text-transform: uppercase; display: flex; align-items: center; justify-content: center; gap: 0.2rem; transition: background 0.2s ease; z-index: 10;">
                          ${consistencyFailed ? '🔄 Fix failed keyframe' : '🔄 Image'}
                        </button>
                      ` : ''}
                    </div>
                    <div class="scene-body">
                      <div class="scene-title">Shot ${s.id} · ${s.role.replaceAll('_', ' ')}</div>
                      <div style="font-size:0.68rem; color:var(--amber); margin:0.15rem 0 0.4rem; line-height:1.35;">${s.purpose}</div>
                      <div class="scene-loc" contenteditable="${state.isEditable}" data-shot-id="${s.id}" style="font-size:0.8rem; min-height: 42px; padding: 4px; border: 1px dashed ${state.isEditable ? 'rgba(255,255,255,0.15)' : 'transparent'}; outline: none; border-radius: 4px; color: var(--text-secondary); word-break: break-word;" title="${state.isEditable ? 'Click to edit visual prompt' : ''}">
                        ${s.loc}
                      </div>
                      <div style="font-family:var(--font-mono); font-size:0.6rem; color:var(--steel-dim); margin-top:0.45rem; text-transform:uppercase;">${s.duration}s · ${s.transitionOut.type}${s.transitionOut.duration ? ` ${s.transitionOut.duration}s` : ''}</div>
                      
                      <% if is_editable %>
                        <div class="scene-actions" style="margin-top: 0.5rem;">
                          <button class="icon-btn lock ${s.locked ? 'active' : ''}" data-i="${i}" title="Lock">${s.locked ? '🔒' : '🔓'}</button>
                          <form action="/projects/${state.projectId}/regenerate_shot" method="post" style="display:inline;">
                            <input type="hidden" name="authenticity_token" value="${document.querySelector("meta[name='csrf-token']").getAttribute("content")}">
                            <input type="hidden" name="shot_id" value="${s.id}">
                            <button type="submit" class="icon-btn" title="Regenerate with Qwen">↻</button>
                          </form>
                        </div>
                      <% end %>
                    </div>
                  </div>
                `;
              }).join("")}
            </div>
          </div>
        `;
      });

      grid.innerHTML = html;

      document.querySelectorAll(".icon-btn.lock").forEach(btn => {
        btn.addEventListener("click", () => {
          if (state.status === "rendering" || state.status === "completed") return;
          const i = +btn.dataset.i;
          state.scenes[i].locked = !state.scenes[i].locked;
          renderStoryboard();
          persistMetadata();
        });
      });

      // Bind camera cycling
      document.querySelectorAll(".cam-tag").forEach(tag => {
        tag.addEventListener("click", () => {
          if (!state.isEditable) return;
          const card = tag.closest(".scene-card");
          const idx = +card.dataset.i;
          const currentCam = state.scenes[idx].camera;
          const camIds = CAMERAS.map(c => c.id);
          const nextIdx = (camIds.indexOf(currentCam) + 1) % camIds.length;
          const nextCam = camIds[nextIdx];
          
          state.scenes[idx].camera = nextCam;
          
          // Sync to rawScreenplay
          const shotId = state.scenes[idx].id;
          if (rawScreenplay.scenes) {
            rawScreenplay.scenes.forEach(scene => {
              if (scene.shots) {
                const shot = scene.shots.find(sh => sh.id.to_s === shotId.to_s);
                if (shot) shot.camera = nextCam;
              }
            });
          }
          
          renderStoryboard();
          showToast(`Shot ${shotId} camera set to: ${nextCam.replace("_", " ")}`);
          persistMetadata();
        });
      });

      // Bind shot visual prompt edits
      document.querySelectorAll(".scene-loc").forEach(node => {
        node.addEventListener("blur", () => {
          if (!state.isEditable) return;
          const shotId = node.dataset.shotId;
          const newText = node.innerText.trim();
          
          // Sync to state.scenes
          const s = state.scenes.find(x => x.id.toString() === shotId.toString());
          if (s) {
            if (s.loc === newText) return; // No change
            s.loc = newText;
          }
          
          // Sync to rawScreenplay
          if (rawScreenplay.scenes) {
            rawScreenplay.scenes.forEach(scene => {
              if (scene.shots) {
                const shot = scene.shots.find(sh => sh.id.toString() === shotId.toString());
                if (shot) {
                  shot.source_visual_prompt = newText;
                  shot.visual_prompt = newText;
                }
              }
            });
          }
          
          showToast(`Shot ${shotId} prompt updated`);
          persistMetadata();
        });
      });
    }

    function renderTimeline() {
      const row = $("timelineRow");
      if (!row) return;
      const clipTotal = state.scenes.reduce((a, s) => a + s.duration, 0);
      const overlapTotal = state.scenes.reduce((a, s) => {
        const transition = s.transitionOut || {};
        return a + (["cut", "match_cut"].includes(transition.type) ? 0 : Number(transition.duration || 0));
      }, 0);
      const total = Math.round((clipTotal - overlapTotal) * 100) / 100;
      $("timelineTotal").textContent = total + "s";
      $("prodDuration").textContent = total + " s";

      row.innerHTML = state.scenes.map((s, i) => {
        return `
          <div class="tl-block" style="flex:${s.duration} 1 0;">
            <div class="lbl">Shot ${s.id}</div>
            <div class="dur">
              <% if is_editable %>
                <button class="dur-btn dec" data-i="${i}">–</button>
              <% end %>
              ${s.duration}s
              <% if is_editable %>
                <button class="dur-btn inc" data-i="${i}">+</button>
              <% end %>
            </div>
          </div>
        `;
      }).join("");

      document.querySelectorAll(".dur-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          if (state.status === "rendering" || state.status === "completed") return;
          const i = +btn.dataset.i;
          const isInc = btn.classList.contains("inc");
          const step = isInc ? 1 : -1;
          const nextDur = state.scenes[i].duration + step;
          if (nextDur < 2 || nextDur > 10) return;

          state.scenes[i].duration = nextDur;
          renderTimeline();
          persistMetadata();
        });
      });
    }

    // 5. Initialize views
    renderGenes();
    renderDirectionControls();
    renderStoryboard();
    renderTimeline();

    // Auto-select tab on load based on status
    if (state.status === "planning") {
      const checkpointStage = <%= checkpoint_stage.to_json.html_safe %>;
      if (["assets", "storyboard", "visual_qa", "completed"].includes(checkpointStage)) {
        switchWizardTab("storyboard");
      } else if (checkpointStage === "screenplay") {
        switchWizardTab("assets");
      } else {
        switchWizardTab("script");
      }
    } else if (state.status === "rendering") {
      switchWizardTab("storyboard");
    } else if (state.status === "completed") {
      switchWizardTab("storyboard");
    } else {
      switchWizardTab("script");
    }

    // Bind Screenplay Script text edits
    const scriptHeadingNode = document.querySelector(".script-heading");
    if (scriptHeadingNode) {
      const scriptContainer = scriptHeadingNode.closest(".panel");
      if (scriptContainer) {
        scriptContainer.addEventListener("blur", (e) => {
          if (!state.isEditable) return;
          const target = e.target;
          if (!target.hasAttribute("contenteditable")) return;
          
          const sceneIdx = parseInt(target.dataset.sceneIdx, 10);
          const field = target.dataset.field;
          const newText = target.innerText.trim();
          
          if (isNaN(sceneIdx)) return;
          
          if (["heading", "action", "objective", "conflict", "turn", "outcome"].includes(field)) {
            rawScreenplay.scenes[sceneIdx][field] = newText;
          } else if (field === "character" || field === "line") {
            const dlgIdx = parseInt(target.dataset.dlgIdx, 10);
            if (!isNaN(dlgIdx) && rawScreenplay.scenes[sceneIdx].dialogue && rawScreenplay.scenes[sceneIdx].dialogue[dlgIdx]) {
              rawScreenplay.scenes[sceneIdx].dialogue[dlgIdx][field] = newText;
            }
          }
          
          showToast("Screenplay script updated");
          persistMetadata();
        }, true); // Use capture phase because blur doesn't bubble
      }
    }

    // 6. ActionCable WebSockets Listener for live progress
    if (state.status === "rendering" || state.status === "planning") {
      const protocol = window.location.protocol === "https:" ? "wss:" : "ws:";
      const wsUrl = `${protocol}//${window.location.host}/cable`;
      const socket = new WebSocket(wsUrl);

      socket.onopen = () => {
        socket.send(JSON.stringify({
          command: "subscribe",
          identifier: JSON.stringify({ channel: "ProjectChannel", id: state.projectId })
        }));
      };

      socket.onmessage = (event) => {
        const response = JSON.parse(event.data);
        if (response.type === "ping" || !response.message) return;

        const data = response.message;
        const terminalLog = $("terminal-log");

        if (data.type === "progress" && terminalLog) {
          const item = document.createElement("div");
          item.innerText = `▶ ${data.message}`;
          terminalLog.appendChild(item);
          terminalLog.scrollTop = terminalLog.scrollHeight;
          if (data.progress) {
            const fill = $("pipeline-progress-fill");
            const label = $("pipeline-progress-label");
            if (fill) fill.style.width = `${Math.max(0, Math.min(100, data.progress))}%`;
            if (label && data.stage) label.textContent = data.stage.replaceAll("_", " ").replace(/\b\w/g, char => char.toUpperCase());
            document.querySelectorAll("[data-pipeline-stage]").forEach((node) => {
              node.classList.toggle("active", node.dataset.pipelineStage === data.stage);
            });
          }
        } else if (data.type === "status") {
          window.location.reload();
        }
      };

      socket.onerror = () => {
        setTimeout(() => window.location.reload(), 8000);
      };
    }
  })();
</script>
