<% content_for :title, "Showrunner Architecture" %>

<style>
  .architecture-page {
    --arch-surface: rgba(17, 20, 25, .72);
    --arch-surface-strong: rgba(12, 14, 18, .9);
    --arch-line: rgba(255, 255, 255, .09);
    --arch-amber: #e3a34d;
    --arch-teal: #55c5bb;
    --arch-red: #f26a63;
    padding-bottom: 5rem;
    overflow-x: hidden;
  }
  .architecture-page * { box-sizing: border-box; }
  .arch-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(2.7rem, 6vw, 5.5rem) clamp(1.2rem, 4vw, 4rem);
    margin-bottom: 2rem;
    border: 1px solid var(--arch-line);
    border-radius: 28px;
    background:
      radial-gradient(circle at 18% 10%, rgba(227,163,77,.16), transparent 34%),
      radial-gradient(circle at 92% 18%, rgba(85,197,187,.14), transparent 35%),
      linear-gradient(145deg, rgba(22,21,22,.96), rgba(9,14,17,.92));
    box-shadow: 0 35px 90px rgba(0,0,0,.34), inset 0 1px rgba(255,255,255,.05);
  }
  .arch-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: .25;
    background-image: linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: linear-gradient(to bottom, black, transparent 82%);
  }
  .arch-hero__content { position: relative; z-index: 1; max-width: 920px; }
  .arch-kicker, .arch-eyebrow {
    font: 700 .68rem/1.2 var(--font-mono);
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .arch-kicker { color: var(--arch-amber); }
  .arch-hero h1 {
    max-width: 850px;
    margin: .85rem 0 1rem;
    color: var(--parchment);
    font-size: clamp(2.3rem, 5.6vw, 5rem);
    font-weight: 520;
    line-height: .98;
    letter-spacing: -.045em;
  }
  .arch-hero h1 em { color: var(--arch-amber); font-weight: inherit; }
  .arch-hero p { max-width: 780px; margin: 0; color: var(--steel); font-size: clamp(.96rem, 1.6vw, 1.12rem); line-height: 1.7; }
  .arch-meta { display: flex; flex-wrap: wrap; gap: .65rem; margin-top: 1.6rem; }
  .arch-chip {
    display: inline-flex;
    align-items: center;
    gap: .48rem;
    padding: .48rem .76rem;
    border: 1px solid var(--arch-line);
    border-radius: 999px;
    background: rgba(255,255,255,.035);
    color: var(--steel);
    font: 650 .67rem/1 var(--font-mono);
  }
  .arch-chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--arch-teal); box-shadow: 0 0 13px var(--arch-teal); }
  .arch-nav { display: flex; flex-wrap: wrap; gap: .55rem; margin: 0 0 2.4rem; }
  .arch-nav a { padding: .55rem .8rem; border: 1px solid var(--arch-line); border-radius: 10px; color: var(--steel); text-decoration: none; font: 650 .66rem/1 var(--font-mono); text-transform: uppercase; letter-spacing: .06em; background: rgba(255,255,255,.02); }
  .arch-nav a:hover { color: var(--parchment); border-color: rgba(227,163,77,.45); background: rgba(227,163,77,.06); }
  .arch-section { margin: 0 0 4rem; scroll-margin-top: 2rem; }
  .arch-section__head { display: grid; grid-template-columns: minmax(0, 1fr) minmax(220px, 420px); gap: 2rem; align-items: end; margin-bottom: 1.35rem; }
  .arch-eyebrow { color: var(--arch-teal); }
  .arch-section h2 { margin: .35rem 0 0; color: var(--parchment); font-size: clamp(1.7rem, 3vw, 2.55rem); font-weight: 540; letter-spacing: -.025em; }
  .arch-section__head p { margin: 0; color: var(--steel); font-size: .88rem; line-height: 1.65; }
  .arch-glass {
    border: 1px solid var(--arch-line);
    border-radius: 20px;
    background: var(--arch-surface);
    backdrop-filter: blur(18px);
    box-shadow: 0 22px 55px rgba(0,0,0,.22), inset 0 1px rgba(255,255,255,.035);
  }
  .arch-diagram-shell { position: relative; width: 100%; max-width: 100%; overflow-x: auto; padding: 1rem; }
  .arch-diagram-shell svg { display: block; width: 100%; min-width: 1180px; height: auto; font-family: var(--font-mono); }
  .arch-diagram-legend { display: flex; flex-wrap: wrap; gap: .8rem 1.2rem; padding: 0 1.2rem 1.1rem; color: var(--steel); font: 650 .64rem var(--font-mono); }
  .arch-diagram-legend span { display: inline-flex; align-items: center; gap: .42rem; }
  .arch-diagram-legend i { width: 18px; height: 3px; border-radius: 999px; background: var(--arch-teal); }
  .arch-diagram-legend .is-amber { background: var(--arch-amber); }
  .arch-diagram-legend .is-red { background: var(--arch-red); }
  .arch-diagram-legend .is-dashed { height: 0; border-top: 2px dashed #78808c; background: transparent; }
  .arch-diagram-hint { display: none; margin: 0 1.1rem 1rem; color: var(--steel-dim); font: 650 .6rem var(--font-mono); text-transform: uppercase; letter-spacing: .07em; }
  .arch-pipeline { display: grid; grid-template-columns: repeat(6, minmax(170px, 1fr)); gap: .8rem; width: 100%; max-width: 100%; min-width: 0; padding: 1rem; overflow-x: auto; }
  .arch-stage { position: relative; min-height: 210px; padding: 1rem; border: 1px solid var(--arch-line); border-radius: 14px; background: linear-gradient(160deg, rgba(255,255,255,.04), rgba(255,255,255,.012)); }
  .arch-stage:not(:last-child)::after { content: "→"; position: absolute; z-index: 2; right: -.72rem; top: 47%; color: var(--arch-amber); font: 700 1rem var(--font-mono); }
  .arch-stage__number { color: var(--arch-amber); font: 800 .72rem var(--font-mono); letter-spacing: .08em; }
  .arch-stage h3 { margin: 1.55rem 0 .65rem; color: var(--parchment); font-size: 1rem; line-height: 1.25; }
  .arch-stage p { margin: 0; color: var(--steel); font-size: .76rem; line-height: 1.55; }
  .arch-stage__state { position: absolute; left: 1rem; bottom: 1rem; color: var(--arch-teal); font: 700 .6rem var(--font-mono); text-transform: uppercase; letter-spacing: .08em; }
  .arch-topology { display: grid; grid-template-columns: 1fr 1.25fr 1.25fr 1fr; gap: 1rem; padding: 1rem; }
  .arch-lane { min-width: 0; padding: 1rem; border-radius: 15px; background: rgba(5,7,10,.34); border: 1px solid var(--arch-line); }
  .arch-lane__title { margin-bottom: .8rem; color: var(--steel); font: 750 .64rem var(--font-mono); letter-spacing: .09em; text-transform: uppercase; }
  .arch-node { position: relative; padding: .8rem; margin-top: .55rem; border: 1px solid var(--arch-line); border-radius: 11px; background: rgba(255,255,255,.025); }
  .arch-node strong { display: block; color: var(--parchment); font-size: .82rem; }
  .arch-node span { display: block; margin-top: .25rem; color: var(--steel-dim); font-size: .68rem; line-height: 1.45; }
  .arch-node[data-tone="teal"] { border-color: rgba(85,197,187,.28); }
  .arch-node[data-tone="amber"] { border-color: rgba(227,163,77,.3); }
  .arch-node[data-tone="red"] { border-color: rgba(242,106,99,.28); }
  .arch-contract-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: .85rem; }
  .arch-contract { padding: 1.1rem; }
  .arch-score { color: var(--arch-amber); font: 800 1.45rem var(--font-mono); }
  .arch-contract h3 { margin: .75rem 0 .45rem; color: var(--parchment); font-size: .98rem; }
  .arch-contract p { margin: 0; color: var(--steel); font-size: .76rem; line-height: 1.55; }
  .arch-boundary { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; align-items: stretch; margin-top: 1rem; }
  .arch-boundary__column { padding: 1.2rem; }
  .arch-boundary__column h3 { margin: 0 0 .75rem; color: var(--parchment); font-size: 1rem; }
  .arch-boundary__column ul { margin: 0; padding-left: 1.05rem; color: var(--steel); font-size: .78rem; line-height: 1.8; }
  .arch-boundary__divider { display: grid; place-items: center; color: var(--arch-amber); font: 800 .64rem var(--font-mono); text-transform: uppercase; writing-mode: vertical-rl; letter-spacing: .1em; }
  .arch-mode-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .arch-mode { padding: 1.35rem; }
  .arch-mode__tag { color: var(--arch-teal); font: 800 .64rem var(--font-mono); letter-spacing: .1em; text-transform: uppercase; }
  .arch-mode--control .arch-mode__tag { color: var(--arch-amber); }
  .arch-mode h3 { margin: .6rem 0 .45rem; color: var(--parchment); font-size: 1.25rem; }
  .arch-mode p { margin: 0 0 .9rem; color: var(--steel); font-size: .82rem; line-height: 1.6; }
  .arch-mode ul { margin: 0; padding-left: 1.05rem; color: var(--steel); font-size: .76rem; line-height: 1.75; }
  .arch-recovery { display: grid; grid-template-columns: repeat(5, minmax(145px, 1fr)); gap: .7rem; width: 100%; max-width: 100%; min-width: 0; padding: 1rem; overflow-x: auto; }
  .arch-recovery__step { min-width: 145px; padding: .95rem; border-radius: 12px; border: 1px solid var(--arch-line); background: rgba(255,255,255,.025); }
  .arch-recovery__step small { color: var(--arch-amber); font: 750 .59rem var(--font-mono); text-transform: uppercase; }
  .arch-recovery__step strong { display: block; margin: .65rem 0 .35rem; color: var(--parchment); font-size: .82rem; }
  .arch-recovery__step span { color: var(--steel); font-size: .69rem; line-height: 1.45; }
  .arch-component-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .8rem; }
  .arch-component { padding: 1.05rem; }
  .arch-component code { color: var(--arch-teal); font: 700 .72rem var(--font-mono); }
  .arch-component h3 { margin: .65rem 0 .4rem; color: var(--parchment); font-size: .93rem; }
  .arch-component p { margin: 0; color: var(--steel); font-size: .74rem; line-height: 1.55; }
  .arch-data-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 1rem; }
  .arch-data-card { padding: 1.2rem; }
  .arch-data-card h3 { margin: 0 0 .85rem; color: var(--parchment); font-size: 1rem; }
  .arch-data-list { display: grid; gap: .5rem; }
  .arch-data-row { display: grid; grid-template-columns: minmax(120px, .4fr) 1fr; gap: .8rem; padding: .7rem 0; border-top: 1px solid var(--arch-line); }
  .arch-data-row code { color: var(--arch-amber); font: 700 .67rem var(--font-mono); overflow-wrap: anywhere; }
  .arch-data-row span { color: var(--steel); font-size: .73rem; line-height: 1.5; }
  .arch-callout { padding: 1.15rem; border-color: rgba(85,197,187,.3); background: linear-gradient(145deg, rgba(85,197,187,.075), rgba(17,20,25,.78)); }
  .arch-callout strong { display: block; color: var(--parchment); font-size: .92rem; }
  .arch-callout p { margin: .45rem 0 0; color: var(--steel); font-size: .75rem; line-height: 1.6; }
  .arch-callout code { overflow-wrap: anywhere; }
  .arch-footer { display: flex; justify-content: space-between; gap: 1rem; padding: 1.2rem 0; border-top: 1px solid var(--arch-line); color: var(--steel-dim); font: .66rem var(--font-mono); }
  @media (max-width: 1050px) {
    .arch-topology, .arch-contract-grid, .arch-component-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .arch-section__head, .arch-mode-grid, .arch-data-grid, .arch-topology, .arch-contract-grid, .arch-component-grid { grid-template-columns: 1fr; }
    .arch-boundary { grid-template-columns: 1fr; }
    .arch-boundary__divider { writing-mode: horizontal-tb; }
    .arch-footer { flex-direction: column; }
    .arch-diagram-hint { display: block; }
  }
</style>

<div class="wrap architecture-page">
  <div class="topbar">
    <div class="brand">
      <%= link_to projects_path, aria: { label: "Back to projects" } do %><div class="mark"></div><% end %>
      <div class="word">SHOWRUNNER <span>· system architecture</span></div>
    </div>
    <div style="display:flex; gap:.7rem; align-items:center; flex-wrap:wrap; justify-content:flex-end;">
      <%= link_to "← Dashboard", projects_path, class: "btn btn-ghost", style: "font:700 .67rem var(--font-mono); text-transform:uppercase;" %>
      <div class="status-pill done"><div class="dot"></div><span>Runtime v4</span></div>
    </div>
  </div>

  <header class="arch-hero">
    <div class="arch-hero__content">
      <div class="arch-kicker">Consistency-first generative film system</div>
      <h1>From one story input to a <em>contract-bound</em> final cut.</h1>
      <p>
        Showrunner is a generic short-film pipeline that preserves narrative intent, recurring identity,
        physical scale, objects, locations and temporal state while retaining creative freedom in camera,
        lighting, rhythm and sound direction.
      </p>
      <div class="arch-meta">
        <span class="arch-chip"><%= @architecture_version %></span>
        <span class="arch-chip">Durable canonical media</span>
        <span class="arch-chip">Two-stage visual QA</span>
        <span class="arch-chip">Explicit producer control</span>
      </div>
    </div>
  </header>

  <nav class="arch-nav" aria-label="Architecture sections">
    <a href="#diagram">Diagram</a><a href="#pipeline">Pipeline</a><a href="#topology">Topology</a><a href="#consistency">Consistency</a>
    <a href="#modes">Modes</a><a href="#recovery">Recovery</a><a href="#components">Components</a><a href="#data">Data</a>
  </nav>

  <section class="arch-section" id="diagram">
    <div class="arch-section__head">
      <div><div class="arch-eyebrow">Reference architecture</div><h2>End-to-end system diagram.</h2></div>
      <p>The primary production path runs left to right. Supporting services below enforce durable state, provider boundaries and targeted recovery.</p>
    </div>
    <div class="arch-glass">
      <div class="arch-diagram-shell">
        <svg id="systemArchitectureDiagram" viewBox="0 0 1740 820" role="img" aria-labelledby="architectureDiagramTitle architectureDiagramDescription">
          <title id="architectureDiagramTitle">Showrunner consistency-first system architecture</title>
          <desc id="architectureDiagramDescription">Flow from user input through Rails orchestration, canonical pre-production, storyboard QA, video synthesis, final video QA and delivery, with Qwen, HappyHorse, durable media, PostgreSQL, Redis, audio and FFmpeg support.</desc>
          <defs>
            <linearGradient id="diagramBg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#12161b"/><stop offset="1" stop-color="#090d11"/></linearGradient>
            <linearGradient id="nodeAmber" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#2b2117"/><stop offset="1" stop-color="#171718"/></linearGradient>
            <linearGradient id="nodeTeal" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#142524"/><stop offset="1" stop-color="#15191d"/></linearGradient>
            <linearGradient id="nodeRed" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#2a191b"/><stop offset="1" stop-color="#17181c"/></linearGradient>
            <filter id="nodeShadow" x="-20%" y="-20%" width="140%" height="150%"><feDropShadow dx="0" dy="9" stdDeviation="11" flood-color="#000" flood-opacity=".38"/></filter>
            <marker id="arrowTeal" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M0 0L10 5L0 10Z" fill="#55c5bb"/></marker>
            <marker id="arrowAmber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M0 0L10 5L0 10Z" fill="#e3a34d"/></marker>
            <marker id="arrowRed" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto"><path d="M0 0L10 5L0 10Z" fill="#f26a63"/></marker>
            <marker id="arrowMuted" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"><path d="M0 0L10 5L0 10Z" fill="#78808c"/></marker>
            <style>
              .dg-lane{fill:url(#diagramBg);stroke:rgba(255,255,255,.08);stroke-width:1.2}.dg-lane-title{fill:#7f8793;font-size:11px;font-weight:800;letter-spacing:1.7px}.dg-node{stroke-width:1.4;filter:url(#nodeShadow)}.dg-node-amber{fill:url(#nodeAmber);stroke:#8c6331}.dg-node-teal{fill:url(#nodeTeal);stroke:#337d77}.dg-node-red{fill:url(#nodeRed);stroke:#8d403c}.dg-node-neutral{fill:#15191f;stroke:#3b424c}.dg-title{fill:#f0ece4;font-size:15px;font-weight:800}.dg-sub{fill:#939aa5;font-size:10.5px}.dg-chip{fill:#0c1014;stroke:rgba(255,255,255,.1)}.dg-chip-text{fill:#aeb5bf;font-size:9px;font-weight:700}.dg-flow{fill:none;stroke:#55c5bb;stroke-width:2.4;marker-end:url(#arrowTeal)}.dg-policy{fill:none;stroke:#e3a34d;stroke-width:2;marker-end:url(#arrowAmber)}.dg-failure{fill:none;stroke:#f26a63;stroke-width:2;stroke-dasharray:7 6;marker-end:url(#arrowRed)}.dg-support{fill:none;stroke:#78808c;stroke-width:1.4;stroke-dasharray:5 5;marker-end:url(#arrowMuted)}.dg-label{fill:#aeb5bf;font-size:9px;font-weight:700}.dg-pass{fill:#55c5bb;font-size:9px;font-weight:800}.dg-fail{fill:#f26a63;font-size:9px;font-weight:800}
            </style>
          </defs>

          <rect class="dg-lane" x="20" y="28" width="1700" height="438" rx="22"/>
          <text class="dg-lane-title" x="48" y="58">PRIMARY PRODUCTION PATH · CONTROL + CONSISTENCY GATES</text>
          <rect class="dg-lane" x="20" y="490" width="1700" height="300" rx="22"/>
          <text class="dg-lane-title" x="48" y="520">DURABLE STATE · PROVIDERS · DELIVERY INFRASTRUCTURE</text>

          <g aria-label="User and interface">
            <rect class="dg-node dg-node-amber" x="48" y="126" width="196" height="146" rx="15"/>
            <text class="dg-title" x="68" y="157">Producer / API</text><text class="dg-sub" x="68" y="178">Story input + direction</text>
            <rect class="dg-chip" x="68" y="199" width="70" height="24" rx="12"/><text class="dg-chip-text" x="82" y="215">Automatic</text>
            <rect class="dg-chip" x="145" y="199" width="79" height="24" rx="12"/><text class="dg-chip-text" x="158" y="215">Full Control</text>
            <text class="dg-sub" x="68" y="246">Review + explicit authority</text>
          </g>

          <g aria-label="Input policy">
            <rect class="dg-node dg-node-amber" x="304" y="90" width="236" height="110" rx="15"/>
            <text class="dg-title" x="324" y="121">ProjectsController</text><text class="dg-sub" x="324" y="143">Request + one-shot grants</text><text class="dg-sub" x="324" y="161">Token forecast approval</text><text class="dg-sub" x="324" y="179">Mode configuration gate</text>
            <rect class="dg-node dg-node-neutral" x="304" y="232" width="236" height="104" rx="15"/>
            <text class="dg-title" x="324" y="263">ProductionTokenPredictor</text><text class="dg-sub" x="324" y="285">Likely range + repair reserve</text><text class="dg-sub" x="324" y="303">Historical calibration</text><text class="dg-sub" x="324" y="321">Explicit excess authorization</text>
          </g>

          <g aria-label="Pre-production orchestration">
            <rect class="dg-node dg-node-teal" x="600" y="90" width="246" height="110" rx="15"/>
            <text class="dg-title" x="620" y="121">ShowrunnerAgent</text><text class="dg-sub" x="620" y="143">Screenplay + asset profiling</text><text class="dg-sub" x="620" y="161">Continuity + storyboard</text><text class="dg-sub" x="620" y="179">Monotonic checkpoints</text>
            <rect class="dg-node dg-node-neutral" x="600" y="232" width="246" height="104" rx="15"/>
            <text class="dg-title" x="620" y="263">PreproductionCheckpoint</text><text class="dg-sub" x="620" y="285">screenplay → assets → storyboard</text><text class="dg-sub" x="620" y="303">Persist actual usage</text><text class="dg-sub" x="620" y="321">Resume without repurchase</text>
          </g>

          <g aria-label="Canonical consistency contract">
            <rect class="dg-node dg-node-teal" x="906" y="72" width="252" height="118" rx="15"/>
            <text class="dg-title" x="926" y="103">ProductionBible</text><text class="dg-sub" x="926" y="125">Identity · scale · materials</text><text class="dg-sub" x="926" y="143">Physics · agency · negatives</text><text class="dg-sub" x="926" y="161">Narrative / QA reference split</text>
            <rect class="dg-node dg-node-teal" x="906" y="222" width="252" height="118" rx="15"/>
            <text class="dg-title" x="926" y="253">Storyboard Contract</text><text class="dg-sub" x="926" y="275">Atomic action per shot</text><text class="dg-sub" x="926" y="293">Initial → final state</text><text class="dg-sub" x="926" y="311">Continuity plate + EDL</text>
          </g>

          <g aria-label="Storyboard QA gate">
            <rect class="dg-node dg-node-red" x="1218" y="126" width="220" height="146" rx="15"/>
            <text class="dg-title" x="1238" y="157">Storyboard Visual QA</text><text class="dg-sub" x="1238" y="179">Identity ≥ 85</text><text class="dg-sub" x="1238" y="197">Props ≥ 85 · Scale ≥ 90</text><text class="dg-sub" x="1238" y="215">Physics ≥ 85 · Overall ≥ 85</text>
            <rect class="dg-chip" x="1238" y="232" width="180" height="24" rx="12"/><text class="dg-chip-text" x="1260" y="248">HARD PRE-VIDEO GATE</text>
          </g>

          <g aria-label="Video render and final QA">
            <rect class="dg-node dg-node-red" x="1492" y="72" width="200" height="118" rx="15"/>
            <text class="dg-title" x="1512" y="103">ProduceDramaJob</text><text class="dg-sub" x="1512" y="125">Single render claim</text><text class="dg-sub" x="1512" y="143">I2V / R2V / T2V</text><text class="dg-sub" x="1512" y="161">Actual cost accounting</text>
            <rect class="dg-node dg-node-red" x="1492" y="222" width="200" height="118" rx="15"/>
            <text class="dg-title" x="1512" y="253">Final Video QA</text><text class="dg-sub" x="1512" y="275">Temporal + visual audit</text><text class="dg-sub" x="1512" y="293">One bounded repair</text><text class="dg-sub" x="1512" y="311">Recoverable final cut</text>
          </g>

          <path class="dg-policy" d="M244 166H304"/><text class="dg-label" x="254" y="157">submit</text>
          <path class="dg-policy" d="M422 200V232"/><text class="dg-label" x="431" y="220">estimate</text>
          <path class="dg-flow" d="M540 144H600"/><text class="dg-label" x="551" y="135">enqueue</text>
